                <script>
                    document.addEventListener("DOMContentLoaded", function() {
                        if (typeof origineDescriptions === 'undefined' || typeof instinctDescriptions === 'undefined') return;

                        function findDescription(type, name) {
                            if (!name || name === 'Aucun' || name === 'Aucune' || name === 'none') return null;
                            
                            if (type === 'Avantage' || type === 'Désavantage' || type === 'Spécial') {
                                for (const key in origineDescriptions) {
                                    const stats = origineDescriptions[key].stats;
                                    if (!stats) continue;
                                    const regex = new RegExp(`<b>${type}(?:\\s+|&nbsp;|&#160;|\\u2013|-)*${name}\\s*:\\s*<\\/b>(.*?)(?:<br|$)`, 's');
                                    const match = stats.match(regex);
                                    if (match) return match[1].trim();
                                }
                            }
                            
                            if (type === "Capacité d'Instinct") {
                                for (const key in instinctDescriptions) {
                                    const stats = instinctDescriptions[key].stats;
                                    if (!stats) continue;
                                    const regex = new RegExp(`<b>Capacité d'Instinct(?:\\s+|&nbsp;|&#160;|\\u2013|-)*${name}\\s*:\\s*<\\/b>(.*?)(?:<br|$)`, 's');
                                    const match = stats.match(regex);
                                    if (match) return match[1].trim();
                                }
                            }
                            return null;
                        }

                        const avEl = document.getElementById('avantageDisplay');
                        if (avEl) {
                            const val = avEl.getAttribute('data-value');
                            if (val !== 'Aucun' && val !== 'none' && val) {
                                const desc = findDescription('Avantage', val) || findDescription('Spécial', val);
                                if (desc) avEl.innerHTML = `<strong>${val} :</strong> ${desc}`;
                            }
                        }

                        const desEl = document.getElementById('desavantageDisplay');
                        if (desEl) {
                            const val = desEl.getAttribute('data-value');
                            if (val !== 'Aucun' && val !== 'none' && val) {
                                const desc = findDescription('Désavantage', val);
                                if (desc) desEl.innerHTML = `<strong>${val} :</strong> ${desc}`;
                            }
                        }

                        const instEl = document.getElementById('instinctDisplay');
                        if (instEl) {
                            const val = instEl.getAttribute('data-value');
                            if (val !== 'Aucune' && val !== 'none' && val) {
                                const desc = findDescription("Capacité d'Instinct", val);
                                if (desc) instEl.innerHTML = `<strong>${val} :</strong> ${desc}`;
                            }
                        }
                    });
                </script>
