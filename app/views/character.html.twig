  <div class="modal-dialog" role="document">
    <div class="modal-content text-dark">
      <div class="modal-header">
        <h5 class="modal-title" id="addItemModalLabel">Ajouter un objet</h5>
        <button type="button" class="close btn btn-link" data-bs-dismiss="modal" aria-label="Close" style="color: black; text-decoration: none; font-size: 1.5rem;">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <ul class="nav nav-tabs" id="itemTabs" role="tablist">
          <li class="nav-item">
            <a class="nav-link active" id="premade-item-tab" data-bs-toggle="tab" href="#premade-item" role="tab">Dans le manuel</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="custom-item-tab" data-bs-toggle="tab" href="#custom-item" role="tab">Objet personnalisé</a>
          </li>
        </ul>
        <div class="tab-content mt-3" id="itemTabsContent">
          <!-- Premade Item -->
          <div class="tab-pane fade show active" id="premade-item" role="tabpanel">
             <div class="form-group">
                <label for="item-select">Sélectionner un objet</label>
                <select id="item-select" class="form-control">
                    <option value="">Sélectionnez...</option>
                    {% for item in equipmentList %}
                        <option value="{{ loop.index0 }}" 
                                data-name="{{ item.name }}" 
                                data-type="{{ item.type }}" 
                                data-stats="{{ item.stats }}" 
                                data-desc="{{ item.desc }}">
                            {{ item.name }} ({{ item.type }}) - {{ item.price }} Or - Rareté {{ item.rarity }}
                        </option>
                    {% endfor %}
                </select>
             </div>
          </div>
          <!-- Custom Item -->
          <div class="tab-pane fade" id="custom-item" role="tabpanel">
             <div class="form-group">
                 <label>Nom</label>
                 <input type="text" id="custom-item-name" class="form-control">
             </div>
             <div class="form-group">
                 <label>Type</label>
                 <input type="text" id="custom-item-type" class="form-control" placeholder="Arme, Armure, Consommable...">
             </div>
             <div class="form-group">
                 <label>Stats</label>
                 <input type="text" id="custom-item-stats" class="form-control">
             </div>
             <div class="form-group">
                 <label>Description</label>
                 <textarea id="custom-item-desc" class="form-control" rows="2"></textarea>
             </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="button" class="btn btn-primary" id="btn-save-item">Ajouter</button>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    var modal = document.getElementById('addItemModal');
    if (modal) {
        document.body.appendChild(modal);
    }
});
</script>
<script src="/js/dashboardInventory.js"></script>

<script src="/js/bootstrap.min.js"></script>
{% endblock %}
