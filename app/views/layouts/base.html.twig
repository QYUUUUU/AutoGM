<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}Assistant GODS
			{% endblock %}
		</title>
		{% block stylesheets %}
			<link rel="stylesheet" href="/css/user.css">
			<link rel="stylesheet" href="/css/general.css">
		{% endblock %}

		<script type="module" src="/js/jquery-3.5.1.slim.min.js"></script>
		
		
		<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css"/>
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
	<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
	<header>
		<nav id="main-navbar" class="navbar navbar-expand-lg navbar-light">
			<!-- Container wrapper -->
			<div class="container d-flex align-items-center justify-content-start no-margin-left">
				<!-- Brand -->
				<a class="logo-brand" href="/home">
					<img src="/images/gods-logo-grey.png">
				</a>
				<!-- Search form -->
				<div class="nav-group">
					<ul class="navbar-nav">
						<li class="nav-item">
							<a class="nav-link" href="/login">Se connecter</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/register">Créer un compte</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/dashboard">Mon Assistant</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/characters">Mes Personnages</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/maps">Les cartes</a></li>
                                                {% if isAdmin %}
                                                <li class="nav-item">
                                                        <a class="nav-link text-warning font-weight-bold" href="/admin/pannel"><i class="fas fa-crown"></i> Dashboard MJ</a>
                                                        <a class="nav-link text-danger font-weight-bold" href="/admin/adversaries"><i class="fas fa-dragon"></i> Bestiary</a>
                                                {% endif %}
						</li>
					</ul>
				</div>
			</div>
		</nav>
	</header>
	<main>
		{% block body %}{% endblock %}
	</main>
</html>
