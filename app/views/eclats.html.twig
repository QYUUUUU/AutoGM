    function populateArtifactCapacitesDropdown(sphere) {
        const select = document.getElementById('artifactCapaciteInput');
        const descElem = document.getElementById('artifactCapaciteDesc');
        
        select.innerHTML = '<option value="">-- Choisir une Capacité --</option>';
        descElem.innerText = '';
        
        // Add Universelle specifically
        if (ECLAT_CAPACITES["Universelle"]) {
            const optgroup = document.createElement('optgroup');
            optgroup.label = "Sphère Universelle";
            ECLAT_CAPACITES["Universelle"].forEach(cap => {
                const opt = document.createElement('option');
                opt.value = cap.nom;
                opt.text = cap.nom;
                opt.dataset.desc = cap.desc;
                optgroup.appendChild(opt);
            });
            select.appendChild(optgroup);
        }
        
        // Add Specific Sphere
        if (sphere && sphere !== "Universelle" && ECLAT_CAPACITES[sphere]) {
            const optgroup = document.createElement('optgroup');
            optgroup.label = `Sphère de ${sphere}`;
            ECLAT_CAPACITES[sphere].forEach(cap => {
                const opt = document.createElement('option');
                opt.value = cap.nom;
                opt.text = cap.nom;
                opt.dataset.desc = cap.desc;
                optgroup.appendChild(opt);
            });
            select.appendChild(optgroup);
        }
        
        // Remove setup listener here, now it's in HTML with showDescAndOptionallyAdd()
    }

    function showDescAndOptionallyAdd() {
