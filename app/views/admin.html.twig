                        </div>
                    </div>

                    <!-- GRAVES -->
                    <div class="d-flex align-items-center flex-nowrap" style="gap: 0.6rem;">
                        <span class="text-white fw-bold text-nowrap" style="font-size:0.85rem; display:inline-block; width: 95px; text-align: right; padding-right: 10px;">Graves (${tG})</span>
                        <div class="btn-group" role="group">
                            <button class="btn btn-sm btn-dark border-secondary text-muted" onclick="changeWound('${c.id}', 'g', ${c.g - 1})">-</button>
                            <span class="btn btn-sm btn-dark border-secondary text-danger fw-bold" style="min-width: 80px; white-space: nowrap; font-size: 1rem; font-family: monospace; display: inline-flex; align-items: center; justify-content: center;">${c.g} / ${c.gMax}</span>
                            <button class="btn btn-sm btn-dark border-secondary text-muted" onclick="changeWound('${c.id}', 'g', ${c.g + 1})">+</button>
                        </div>
                    </div>

                    <!-- MORTELLES -->
                    <div class="d-flex align-items-center flex-nowrap" style="gap: 0.6rem;">
                        <span class="text-white fw-bold text-nowrap" style="font-size:0.85rem; display:inline-block; width: 95px; text-align: right; padding-right: 10px;">Mortelles (${tM})</span>
                        <div class="btn-group" role="group">
                            <button class="btn btn-sm btn-dark border-secondary text-muted" onclick="changeWound('${c.id}', 'm', ${c.m - 1})">-</button>
                            <span class="btn btn-sm btn-dark border-secondary text-white fw-bold" style="min-width: 80px; white-space: nowrap; font-size: 1rem; font-family: monospace; display: inline-flex; align-items: center; justify-content: center;">${c.m} / ${c.mMax}</span>
                            <button class="btn btn-sm btn-dark border-secondary text-muted" onclick="changeWound('${c.id}', 'm', ${c.m + 1})">+</button>
