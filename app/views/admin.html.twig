}
function updateCombatUI() {
    const listAll = document.querySelector("#combatListAll");
    if(listAll) listAll.innerHTML = "";
    
    let attSelect = document.getElementById("atkAttaquant");
    let cibleSelect = document.getElementById("atkCible");
    let prevAtt = attSelect ? attSelect.value : null;
    let prevCib = cibleSelect ? cibleSelect.value : null;
    
    if(attSelect) attSelect.innerHTML = "";
    if(cibleSelect) cibleSelect.innerHTML = "";

    let optPJ_att = document.createElement("optgroup"); optPJ_att.label = "Joueurs (PJ)";
    let optPNJ_att = document.createElement("optgroup"); optPNJ_att.label = "Non-Joueurs (PNJ)";
    let optPJ_cib = document.createElement("optgroup"); optPJ_cib.label = "Joueurs (PJ)";
    let optPNJ_cib = document.createElement("optgroup"); optPNJ_cib.label = "Non-Joueurs (PNJ)";
    
    combatants.forEach(c => {
        if(listAll) listAll.innerHTML += renderRow(c);
        
        let opt = document.createElement("option");
        opt.value = c.id; 
        opt.textContent = c.name + " (" + c.init + ")";
        
        if (c.isPC) {
            optPJ_att.appendChild(opt.cloneNode(true));
            optPJ_cib.appendChild(opt.cloneNode(true));
        } else {
            optPNJ_att.appendChild(opt.cloneNode(true));
            optPNJ_cib.appendChild(opt.cloneNode(true));
        }
    });

    if(attSelect) { attSelect.appendChild(optPJ_att); attSelect.appendChild(optPNJ_att); }
    if(cibleSelect) { cibleSelect.appendChild(optPJ_cib); cibleSelect.appendChild(optPNJ_cib); }
    
    if(prevAtt && combatants.find(c=>c.id==prevAtt) && attSelect) attSelect.value = prevAtt;
    if(prevCib && combatants.find(c=>c.id==prevCib) && cibleSelect) cibleSelect.value = prevCib;
    
    // Sauvegarder l'état
    localStorage.setItem('combatantsState', JSON.stringify(combatants));
}

function changeInit(id, val) { let c = combatants.find(x=>x.id==id); if(c) { c.init = parseInt(val)||0; /* No auto-sort to prevent jumping */ localStorage.setItem('combatantsState', JSON.stringify(combatants)); } }
function changeArmor(id, val) { let c = combatants.find(x=>x.id==id); if(c) { c.armor = val; localStorage.setItem('combatantsState', JSON.stringify(combatants)); } }
function changeWound(id, type, val) {
    let c = combatants.find(x=>x.id==id);
    if(c) {
        let v = parseInt(val) || 0;
        if(type === 'l') c.l = Math.max(0, Math.min(v, c.lMax));
        if(type === 'g') c.g = Math.max(0, Math.min(v, c.gMax));
        if(type === 'm') c.m = Math.max(0, Math.min(v, c.mMax));
        updateCombatUI();
    }
}

document.getElementById('atkArme').addEventListener('change', function(e) {
    if(this.value === 'custom') {
        document.getElementById('atkArmeCustom').style.display = 'block';
    } else {
        document.getElementById('atkArmeCustom').style.display = 'none';
        let parts = this.value.split(','); // "1D6,P"
        if(parts.length > 1) document.getElementById('atkType').value = parts[1];
    }
});

function logAction(msg) {
    let box = document.getElementById("combatLog");
    if(box) {
        box.innerHTML += "<div>" + msg + "</div>";
        box.scrollTop = box.scrollHeight;
    }
}

function resolveAttack() {
    let attId = document.getElementById("atkAttaquant").value;
    let cibId = document.getElementById("atkCible").value;
    
    let atkJetInput = document.getElementById("atkJet").value;
    let defJetInput = document.getElementById("defJet").value;
    
    let att = combatants.find(c=>c.id==attId);
    let cib = combatants.find(c=>c.id==cibId);
    
    if(!att || !cib) return alert("Sélectionnez les cibles.");
    
    let atkJet = parseInt(atkJetInput);
    if(isNaN(atkJet)) {
        if (!att.isPC && att.npcData) {
            let pool = parseInt(att.npcData.atk) || parseInt(att.npcData.contact) || parseInt(att.npcData.act) || 3;
            let diff = 7;
            let rolls = [];
            atkJet = 0;
            for(let i=0; i<pool; i++){ let r = Math.floor(Math.random()*10)+1; rolls.push(r); if(r>=diff) atkJet++; }
            logAction(`=> 🎲 Attaque Auto PNJ (${att.name}) : ${pool}D10 vs ${diff} -> [${rolls.join(', ')}] = ${atkJet} réussite(s)`);
        } else {
            atkJet = 0;
        }
    }

    let defJet = parseInt(defJetInput);
    if(isNaN(defJet)) {
        if (!cib.isPC && cib.npcData) {
            let pool = parseInt(cib.npcData.contact) || parseInt(cib.npcData.act) || 3;
            let diff = 7;
            let rolls = [];
            defJet = 0;
            for(let i=0; i<pool; i++){ let r = Math.floor(Math.random()*10)+1; rolls.push(r); if(r>=diff) defJet++; }
            logAction(`=> 🛡️ Défense Auto PNJ (${cib.name}) : ${pool}D10 vs ${diff} -> [${rolls.join(', ')}] = ${defJet} réussite(s)`);
        } else {
            defJet = 0;
        }
    }
    
    logAction(`<hr class="border-secondary my-1">`);
    logAction(`🥊 <b>${att.name}</b> attaque <b>${cib.name}</b>`);
    logAction(`=> Résolution : ${atkJet} R. (Attaque) VS ${defJet} R. (Défense)`);
    
    if(defJet >= atkJet) {
        let margin = defJet - atkJet;
        let cAttack = margin >= 3 ? " <span class='text-warning'>(Contre-attaque dispo!)</span>" : "";
        return logAction(`<span class="text-info align-items-center">🛡️ Défense réussie!${cAttack} Aucun dommage.</span>`);
    }
    
    // Attaquant gagne
    let successes = atkJet; // les dommages de la base de l'arme + réussites du jet
    
    let weaponVal = document.getElementById("atkArme").value;
    let diceExpression = "";
    let type = "P";
    
    if(weaponVal === "custom") {
        diceExpression = document.getElementById("atkArmeCustom").value.toUpperCase();
        type = "P";
    } else {
        let parts = weaponVal.split(',');
        diceExpression = parts[0];
        type = parts[1];
    }
    
    let baseDmg = 0;
    let m = diceExpression.match(/(\d+)D(\d+)/);
    if(m) {
        let n = parseInt(m[1]);
        let d = parseInt(m[2]);
        let rolls = [];
        for(let i=0; i<n; i++) {
            let r = Math.floor(Math.random()*d)+1;
            rolls.push(r);
            baseDmg += r;
        }
        logAction(`=> Dégâts arme (${diceExpression}): [${rolls.join('+')}] = ${baseDmg} (${type})`);
    } else {
        baseDmg = parseInt(diceExpression) || 0;
        logAction(`=> Dégâts arme (fixes): ${baseDmg} (${type})`);
    }
    
    let totalDmg = baseDmg + successes;
    logAction(`=> Dégâts bruts: ${baseDmg} (arme) + ${successes} (réussites) = ${totalDmg} (${type})`);
    
    // Soustraction armure
    let armorValue = getArmorVal(cib.armor, type);
    let finalDmg = Math.max(0, totalDmg - armorValue);
    
    logAction(`=> Armure cible (${cib.armor}): absorbe ${armorValue} pt(s)`);
    
    if(finalDmg <= 0) {
        logAction(`<span class="text-success">=> L'armure absorbe la totalité ! 0 Dégât net.</span>`);
    } else {
        logAction(`<span class="text-danger">=> <b>${cib.name}</b> subit <b>${finalDmg} Dégâts nets</b>. (Mettez à jour les coche(s) de Blessure manuellement)</span>`);
    }
}
function generateBestiaryPNJ() {
    const sel = document.getElementById("bestiaryQuickSelect");
    if (!sel.value) return alert("Sélectionnez un adversaire dans le Bestiaire.");
    const opt = sel.options[sel.selectedIndex];
    
    let baseName = sel.value;
    let l = parseInt(opt.getAttribute('data-l')) || 3;
    let g = parseInt(opt.getAttribute('data-g')) || 2;
    let m = parseInt(opt.getAttribute('data-m')) || 1;
    
    let armText = (opt.getAttribute('data-arm') || "").toLowerCase();
    let arm = "0,0,0";
    let match = armText.match(/(\d+)/);
    if (match) {
        let n = parseInt(match[1]);
        arm = n + ',' + n + ',' + n;
    }
    
    let reactText = opt.getAttribute('data-react') || "";
    let reactMatch = reactText.match(/(\d+)/);
    let react = reactMatch ? parseInt(reactMatch[1]) : 2;

    let npcData = {
        atk: opt.getAttribute('data-atk') || "",
        act: opt.getAttribute('data-act') || "",
        contact: opt.getAttribute('data-contact') || "",
        spec: opt.getAttribute('data-spec') || "",
        specdet: opt.getAttribute('data-specdet') || "",
        rel: opt.getAttribute('data-rel') || "",
        res: opt.getAttribute('data-res') || "",
        arme: opt.getAttribute('data-arme') || "",
        cap: opt.getAttribute('data-cap') || "",
        desc: opt.getAttribute('data-desc') || "",
        reactRaw: opt.getAttribute('data-react') || "",
        armRaw: opt.getAttribute('data-arm') || "",
        lRaw: opt.getAttribute('data-l') || "",
        gRaw: opt.getAttribute('data-g') || "",
        mRaw: opt.getAttribute('data-m') || ""
    };

    let count = combatants.filter(c => c.name.startsWith(baseName)).length;
    let finalName = count > 0 ? baseName + " " + (count + 1) : baseName;

    combatants.push({
        id: "npc_best_"+Date.now(),
        isPC: false,
        name: finalName,
        reaction: react,
        init: 0,
        armor: arm,
        lMax: l,
        gMax: g,
        mMax: m,
        l: 0,
        g: 0,
        m: 0,
        npcData: npcData
    });
    updateCombatUI();
    localStorage.setItem('combatantsState', JSON.stringify(combatants));
    logAction('=> Génération depuis Bestiaire: <b>' + finalName + '</b> (L:' + l + ' G:' + g + ' M:' + m + ')');
}

</script>

<script src="/js/dashboardTrackRolls.js"></script>

<script>
// --- TABS SYSTEM ---
let encounters = {};
let activeTabId = "default";
let tabsInitDone = false;

function initTabs() {
    let saved = localStorage.getItem('gmTabsState');
    if(saved) {
        try {
            encounters = JSON.parse(saved);
        } catch(e) {
            encounters = { "default": { name: "Scène Principale", combatants: combatants } };
        }
    } else {
        encounters = { "default": { name: "Scène Principale", combatants: combatants } };
    }
    
    // Assure au moins un tab
    if(Object.keys(encounters).length === 0) encounters = { "default": { name: "Scène Principale", combatants: [] } };
    if(!encounters[activeTabId]) activeTabId = Object.keys(encounters)[0];
    
    combatants = encounters[activeTabId].combatants || [];
    tabsInitDone = true;
    renderTabs();
    updateCombatUI();
}

function renderTabs() {
    const ul = document.getElementById('encountersTabs');
    if(!ul) return;
    ul.innerHTML = '';
    
    for(let tId in encounters) {
        const li = document.createElement('li');
        li.className = 'nav-item position-relative';
        
        const isAct = (tId === activeTabId);
        
        li.innerHTML = `<button class="nav-link ${isAct ? 'active fw-bold text-warning border-secondary bg-dark' : 'text-white-50 border-0 bg-transparent'}" 
            onclick="switchTab('${tId}')" style="cursor: pointer; border-bottom: ${isAct ? 'none' : '2px solid transparent'};">${encounters[tId].name}
            ${isAct && Object.keys(encounters).length > 1 ? '<i class="fas fa-times text-danger ms-2" onclick="deleteTab(event, \''+tId+'\')" title="Fermer Scène"></i>' : ''}
            </button>`;
        ul.appendChild(li);
    }
    
    ul.innerHTML += `<li class="nav-item">
        <button class="nav-link text-success fw-bold border-0 bg-transparent" onclick="createNewEncounterTab()" style="cursor: pointer;"><i class="fas fa-plus"></i> Nouvelle Scène</button>
    </li>`;
}

function switchTab(tId) {
    if(!encounters[tId]) return;
    saveCurrentTabState();
    
    activeTabId = tId;
    combatants = encounters[activeTabId].combatants || [];
    renderTabs();
    updateCombatUI();
}

function saveCurrentTabState() {
    if (!tabsInitDone) return;
    if(encounters[activeTabId]) {
        encounters[activeTabId].combatants = combatants;
    }
    localStorage.setItem('gmTabsState', JSON.stringify(encounters));
}

function createNewEncounterTab() {
    let name = prompt("Nom de la nouvelle scène (ex: Embuscade Forêt, Donjon final...) :");
    if(!name) return;
    
    let newId = "tab_" + Date.now();
    saveCurrentTabState();
    
    encounters[newId] = { name: name, combatants: [] };
    activeTabId = newId;
    combatants = encounters[newId].combatants;
    
    renderTabs();
    updateCombatUI();
    saveCurrentTabState();
}

function deleteTab(e, tId) {
    e.stopPropagation();
    if(confirm("Supprimer cette scène et tous ses ennemis ?")) {
        delete encounters[tId];
        activeTabId = Object.keys(encounters)[0];
        combatants = encounters[activeTabId].combatants || [];
        renderTabs();
        updateCombatUI();
        saveCurrentTabState();
    }
}

// Hooking to the end of the updateCombatUI
let originalUpdateCombatUI = updateCombatUI;
updateCombatUI = function() {
    originalUpdateCombatUI();
    saveCurrentTabState();
};

// -- QUICK ROLLS --
function quickStatRoll(name, statName, value, cid, maxRelances) {
    let limitRelances = parseInt(maxRelances) || 0;
    let valStr = String(value).toUpperCase().replace(/\s/g, '');
    let nbDice = parseInt(valStr) || 0;
    let auto = valStr.includes('+') ? (parseInt(valStr.split('+')[1]) || 0) : 0;
    
    if(nbDice <= 0 && auto <= 0) return;
    
    let autoMs = auto > 0 ? ` (+${auto} bonus)` : "";
    let relMsg = limitRelances > 0 ? ` (Relances auto activées: max ${limitRelances})` : "";
    
    logAction(`=> 🎲 ${name} effectue un Test <b>${statName}</b> (Jet : ${nbDice} dés${autoMs})${relMsg}. <span class="text-white-50"><i>Lancement en cours...</i></span>`);
    
    // Simulate auto roll
    setTimeout(() => {
        let rolledValues = [];
        let succes = auto;
        let failedCount = 0;
        
        for(let i=0; i<nbDice; i++) {
            let r = Math.ceil(Math.random() * 10);
            rolledValues.push(r);
            if(r >= 7) succes++;
            else failedCount++;
        }
        
        let textResult = rolledValues.join(" ");
        let finalDisplay = `Résultat: [${textResult}]`;
        
        if (limitRelances > 0 && failedCount > 0) {
            let rerollCount = Math.min(limitRelances, failedCount);
            let rerolledVals = [];
            for(let i=0; i<rerollCount; i++) {
                let r = Math.ceil(Math.random() * 10);
                rerolledVals.push(r);
                if(r >= 7) succes++;
            }
            finalDisplay += ` | Relances utilisées (${rerollCount}) -> [${rerolledVals.join(" ")}]`;
        }
        
        logAction(`<span class="text-warning">=> <b>${name}</b> [${statName}] </span> ${finalDisplay}${autoMs} => <b class="fs-6">${succes} Succès</b> !`);
    }, 400);
}

// Init when page loads
document.addEventListener("DOMContentLoaded", () => {
    setTimeout(initTabs, 500); // let original data load
});

</script>

