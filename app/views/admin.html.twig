                <div style="cursor:pointer;" onclick="quickStatRoll('${esc(c.name)}', 'Action', '${esc(c.npcData.act)}', '${c.id}', 0)" title="Lancer Action" class="stat-clickable"><span class="text-info fw-bold me-1">Action</span> <strong class="text-white bg-dark px-2 py-1 rounded border border-secondary">${c.npcData.act}</strong></div>
                <div style="cursor:pointer;" onclick="quickStatRoll('${esc(c.name)}', 'Caractéristique', '${caracValue}D', '${c.id}', 0)" title="Lancer Caractéristique (ex: Force, Dextérité...)" class="stat-clickable"><span class="text-secondary fw-bold me-1">Carac</span> <strong class="text-white bg-dark px-2 py-1 rounded border border-secondary">${caracValue}D</strong></div>
                <div style="cursor:pointer;" onclick="quickStatRoll('${esc(c.name)}', 'Contact', '${esc(c.npcData.contact)}', '${c.id}', 0)" title="Lancer Contact (Défense ou Esquive)" class="stat-clickable"><span class="text-info fw-bold me-1">Contact</span> <strong class="text-white bg-dark px-2 py-1 rounded border border-secondary">${c.npcData.contact}</strong></div>
                <div><span class="text-info fw-bold me-1">Réserve</span> <strong class="text-white">${c.npcData.res}</strong> <span class="text-light">(${c.npcData.rel} rel)</span></div>
                ${c.npcData.arme ? `<div><span class="text-warning fw-bold me-1">Arme</span> <strong class="text-white">${c.npcData.arme}</strong></div>` : ''}
            </div>
            ${c.npcData.spec ? `<div class="mb-2"><div style="cursor:pointer; display:inline-block;" onclick="quickStatRoll('${esc(c.name)}', 'Spécialité : ${esc(c.npcData.specdet||"Générale")}', '${esc(c.npcData.spec)}', '${c.id}', ${relCount})" title="Lancer Spécialité" class="stat-clickable"><span class="text-primary fw-bold me-2">Spécialité</span> <span class="text-white bg-dark px-2 py-1 rounded border border-secondary">${c.npcData.spec}</span> ${c.npcData.specdet ? `<span class="text-warning fst-italic ms-1">(${c.npcData.specdet})</span>` : ''}</div></div>` : ''}
            ${c.npcData.cap ? `<div><span class="text-warning fw-bold me-2">Capacités</span> <span class="text-white">${c.npcData.cap.replace(/\n/g, ' &bull; ')}</span></div>` : ''}
        </div>
        `;
    }

    return `
    <div class="card mb-4 shadow-sm" style="background-color: ${bgClass}; border: 1px solid #4a4a50; border-left: 6px solid ${borderClass};">
        <div class="card-body p-3">
            <!-- HEADER ROW -->
            <div class="d-flex flex-nowrap align-items-center justify-content-between mb-3 pb-3 border-bottom border-dark" style="gap: 1.5rem;">
                
                <div class="d-flex align-items-center" style="gap: 1.5rem; flex: 1; min-width: 0;">
                    <div class="text-center flex-shrink-0">
                        <label class="text-muted text-uppercase d-block mb-1" style="font-size: 0.65rem; font-weight: bold;">Init</label>
