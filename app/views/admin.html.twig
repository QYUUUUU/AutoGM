                </div>
            </div>

            <!-- WOUNDS ROW -->
            <div class="d-flex flex-wrap align-items-center bg-dark bg-opacity-25 p-3 rounded border border-secondary border-opacity-50 mt-3" style="gap: 1.5rem;">
                <span class="text-muted text-uppercase fw-bold" style="font-size:0.85rem; letter-spacing: 1px;">Blessures <i class="fas fa-heartbeat text-danger ms-1"></i></span>
                
                <div class="d-flex align-items-center flex-wrap" style="gap: 2.5rem;">
                    <!-- LÉGÈRES -->
                    <div class="d-flex align-items-center flex-nowrap" style="gap: 0.6rem;">
