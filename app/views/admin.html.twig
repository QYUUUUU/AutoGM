{% extends '/layouts/base.html.twig' %}

{% block title %}Dashboard MJ - GODS
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .admin-dashboard {
            background-color: rgba(26, 26, 29, 0.65); /* Semi-transparent to show the background */
            min-height: 100vh;
            color: #dcdccc;
            padding: 2rem 0;
            font-family: "Garamond", serif;
            position: relative;
            z-index: 1; /* Keep above the slideshow */
        }
        .mj-card {
            background: rgba(35, 35, 40, 0.82);
            border: 1px solid #4a4a50;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.5);
            margin-bottom: 2rem;
        }
        .mj-card-header {
            background: linear-gradient(180deg, #2b2b30 0%, #1e1e22 100%);
            border-bottom: 2px solid #5a4b3c;
            padding: 1rem 1.5rem;
            border-top-left-radius: 8px;
            border-top-right-radius: 8px;
        }
        .mj-card-title {
            margin: 0;
            color: #d4af37;
            font-size: 1.5rem;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .mj-card-body {
            padding: 1.5rem;
        }
        .mj-label {
            color: #a8a8b8;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
            display: block;
        }
        .mj-select, .mj-input {
            background-color: #151518;
            border: 1px solid #3a3a40;
            color: #fff;
            border-radius: 4px;
        }
        .mj-select:focus, .mj-input:focus {
            background-color: #1e1e22;
            border-color: #a8a8b8;
            color: #fff;
            box-shadow: 0 0 0 0.2rem rgba(168, 168, 184, 0.25);
        }
        .mj-btn-save {
            background-color: #722f37; /* Deep red, avoiding too much gold */
            color: #fff !important;
            border: 1px solid #4a1f24;
            font-size: 1.1rem;
            padding: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
            font-weight: bold;
        }
        .mj-btn-save:hover {
            background-color: #8c3a44;
            color: #fff !important;
            box-shadow: 0 0 10px rgba(114, 47, 55, 0.5);
            border-color: #722f37;
        }
        .moon-icon {
            display: inline-block;
            width: 24px;
            text-align: center;
            margin-right: 10px;
        }
        /* Custom vanilla JS toast styling */
        .toast-custom {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 9999;
            background-color: #198754;
            color: #fff;
            padding: 1rem 1.5rem;
            border-radius: 0.25rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            display: none;
            opacity: 0;
            transition: opacity 0.4s ease-in-out;
            font-family: sans-serif;
        }
    </style>
{% endblock %}

{% block body %}
<!-- Sliding Background (same as dashboard) -->
<div class="bg-slideshow">
    <div class="bg-slide img1"></div>
    <div class="bg-slide img2"></div>
    <div class="bg-slide img3"></div>
    <div class="bg-slide img4"></div>
</div>

<div class="admin-dashboard">
    <div class="container-fluid px-4 px-xl-5">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
            <h1 class="text-white text-uppercase"><i class="fas fa-crown text-warning"></i> Dashboard du Maître de Jeu</h1>
            
            <div class="d-flex align-items-center">
                <label for="groupeSelect" class="text-white mr-2 mb-0 fw-bold">Groupe Actif :</label>
                <select id="groupeSelect" class="form-select mj-select w-auto" onchange="window.location.href='?groupe_id='+this.value">
                    {% if groupes is empty %}
                        <option value="">Aucun groupe trouvé</option>
                    {% else %}
                        {% for groupe in groupes %}
                            <option value="{{ groupe.id }}" {% if groupe.id == activeGroupeId %}selected{% endif %}>{{ groupe.nom }}</option>
                        {% endfor %}
                    {% endif %}
                </select>
                <input type="hidden" id="activeGroupeId" value="{{ activeGroupeId }}">
            </div>

            <span class="badge badge-dark p-2 border border-secondary">Identifié en tant qu'Admin</span>
        </div>

        <div class="row">
            <!-- CALENDRIER SOLAIRE ET LUNAIRE -->
            <div class="col-lg-6">
                <div class="mj-card">
                    <div class="mj-card-header">
                        <h2 class="mj-card-title"><i class="fas fa-sun text-white"></i> Astrologie & Calendrier</h2>
                    </div>
                    <div class="mj-card-body">
                        
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="mj-label">Temps (Journée)</label>
                                    <select class="form-control mj-select" name="timeOfDay" id="timeOfDay">
                                        <option value="Aube" {% if worldState.timeOfDay == 'Aube' %}selected{% endif %}>Aube</option>
                                        <option value="Matin" {% if worldState.timeOfDay == 'Matin' %}selected{% endif %}>Matin</option>
                                        <option value="Midi" {% if worldState.timeOfDay == 'Midi' %}selected{% endif %}>Midi</option>
                                        <option value="Après-midi" {% if worldState.timeOfDay == 'Après-midi' %}selected{% endif %}>Après-midi</option>
                                        <option value="Crépuscule" {% if worldState.timeOfDay == 'Crépuscule' %}selected{% endif %}>Crépuscule</option>
                                        <option value="Nuit" {% if worldState.timeOfDay == 'Nuit' %}selected{% endif %}>Nuit</option>
                                    </select>
                                </div>
                                <div class="col-md-5 mb-3">
                                    <label class="mj-label">Mois / Semaine</label>
                                    <select class="form-control mj-select" name="weekType" id="weekType">
                                        <option value="Eau" {% if worldState.weekType == 'Eau' %}selected{% endif %}>Semaine d'Eau</option>
                                        <option value="Feu" {% if worldState.weekType == 'Feu' %}selected{% endif %}>Semaine de Feu</option>
                                        <option value="Sang" {% if worldState.weekType == 'Sang' %}selected{% endif %}>Semaine de Sang</option>
                                    </select>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="mj-label">Jour</label>
                                    <input type="number" class="form-control mj-input" name="dayNumber" id="dayNumber" min="1" max="7" value="{{ worldState.dayNumber }}">
                                </div>
                            </div>

                            <hr class="border-secondary my-4">

                            <h3 class="text-white mb-4" style="font-size:1.2rem; letter-spacing:1px;"><i class="fas fa-moon text-secondary"></i> Lunes des Terres Sauvages</h3>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="mj-label text-info"><i class="fas fa-circle moon-icon"></i> Sinla (Lune d'Argent)</label>
                                    <select class="form-control mj-select border-info" name="sinlaPhase" id="sinlaPhase">
                                        <option value="Nouvelle" {% if worldState.sinlaPhase == 'Nouvelle' %}selected{% endif %}>Nouvelle Lune</option>
                                        <option value="Croissante" {% if worldState.sinlaPhase == 'Croissante' %}selected{% endif %}>Croissante</option>
                                        <option value="Pleine" {% if worldState.sinlaPhase == 'Pleine' %}selected{% endif %}>Pleine (+ bonus incantations)</option>
                                        <option value="Décroissante" {% if worldState.sinlaPhase == 'Décroissante' %}selected{% endif %}>Décroissante</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="mj-label text-danger"><i class="fas fa-circle text-danger moon-icon"></i> Akhat (Lune Sombre)</label>
                                    <select class="form-control mj-select border-danger" name="akhatState" id="akhatState">
                                        <option value="Eteinte" {% if worldState.akhatState == 'Eteinte' %}selected{% endif %}>Éteinte (Normale)</option>
                                        <option value="Noire" {% if worldState.akhatState == 'Noire' %}selected{% endif %} class="text-warning">Lune Noire (Comportement erratique)</option>
                                        <option value="Funeste" {% if worldState.akhatState == 'Funeste' %}selected{% endif %} class="text-danger font-weight-bold">Lune Funeste (Prédateurs Enragés)</option>
                                    </select>
                                </div>
                            </div>
                            
                            <button type="button" class="btn mj-btn-save btn-block" id="saveWorldBtn">
                                <i class="fas fa-save"></i> Enregistrer le Climat & Temps
                            </button>
                    </div>
                </div>
            </div>

            <!-- GESTION DE GROUPE ET AIDE-MEMOIRE -->
            <div class="col-lg-6">
                <div class="mj-card">
                    <div class="mj-card-header">
                        <h2 class="mj-card-title"><i class="fas fa-users text-white"></i> Groupe & Règles</h2>
                    </div>
                    <div class="mj-card-body">
                        <h3 class="text-white mb-3" style="font-size:1.2rem; letter-spacing:1px;"><i class="fas fa-scroll text-secondary"></i> Lois et Coutumes (Région Actuelle)</h3>
                        <div class="mb-4">
                            <textarea class="form-control mj-input" name="loisCoutumes" id="loisCoutumes" rows="3" placeholder="Ex: Interdiction du port de symboles impériaux, couleurs noires proscrites...">{{ worldState.loisCoutumes }}</textarea>
                        </div>
                        
                        <hr class="border-secondary my-4">

                        <h3 class="text-white mb-3" style="font-size:1.2rem; letter-spacing:1px;"><i class="fas fa-campground text-secondary"></i> Ressources de Groupe</h3>
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="mj-label">Rations (Jours)</label>
                                <input type="number" class="form-control mj-input" name="rations" id="rations" min="0" value="{{ worldState.rations }}">
                            </div>
                            <div class="col-md-8 mb-3">
                                <label class="mj-label">État des Montures</label>
                                <input type="text" class="form-control mj-input" name="etatMontures" id="etatMontures" placeholder="Ex: Reposées, Épuisées, Affamées" value="{{ worldState.etatMontures }}">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="mj-label">Encombrement du Matériel</label>
                            <textarea class="form-control mj-input" name="encombrement" id="encombrement" rows="2" placeholder="Ex: Lourd (Chariot endommagé)">{{ worldState.encombrement }}</textarea>
                        </div>

                        <button type="button" class="btn mj-btn-save btn-block" id="saveWorldBtn2">
                            <i class="fas fa-save"></i> Enregistrer le Groupe
                        </button>
                    </div>
                </div>
            </div>

            <!-- GESTIONNAIRE DE COMBAT -->
            <div class="col-lg-12">
                <div class="mj-card mt-4">
                    <div class="mj-card-header">
                        <h2 class="mj-card-title"><i class="fas fa-swords text-white"></i> Suivi d'Initiative & Combats</h2>
                    </div>
                    <div class="mj-card-body row text-white">
                        <!-- Panel de gauche : Liste de combat -->
                        <div class="col-md-7 border-end border-secondary pe-4">
                            <style>
                                input[type=number]::-webkit-inner-spin-button, 
                                input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
                                input[type=number] { -moz-appearance: textfield; }
                                .stat-box { background: rgba(0,0,0,0.2); border-radius: 6px; padding: 4px 8px; border: 1px solid rgba(255,255,255,0.1); }
                                .stat-label { font-size: 0.65rem; text-transform: uppercase; color: #888; font-weight: bold; letter-spacing: 0.5px; display: block; margin-bottom: 2px; }
                                .stat-val { font-size: 0.95rem; font-weight: bold; color: #eee; } .stat-clickable:hover strong { background-color:#d4af37 !important; color:#000 !important; cursor:pointer; }
                            </style>
                                                        <div class="d-flex flex-column mb-4 pb-3 border-bottom border-secondary">
                                <!-- SYSTEME DE TABS (ENCOUNTERS) -->
                                <ul class="nav nav-tabs mb-3 shadow-sm border-secondary border-opacity-50" id="encountersTabs" style="border-bottom: 2px solid #5a4b3c;">
                                    <!-- Tabs renderisés dynamiquement ici -->
                                    <li class="nav-item">
                                        <button class="nav-link text-success fw-bold border-0 bg-transparent" onclick="createNewEncounterTab()" style="cursor: pointer;"><i class="fas fa-plus"></i> Nouvelle Scène</button>
                                    </li>
                                </ul>

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h4 class="mb-0 text-info"><i class="fas fa-list-ol"></i> Ordre d'Action</h4>
                                    <button class="btn btn-sm btn-outline-danger" onclick="clearCombatants()"><i class="fas fa-trash-alt"></i> Vider Ennemis</button>
                                </div>
                                <div class="d-flex flex-wrap align-items-center justify-content-between bg-dark p-3 rounded border border-secondary shadow-sm">
                                    <div class="d-flex flex-wrap align-items-center mb-2 mb-md-0">
                                        <span class="text-white-50 ms-2 me-3 small fw-bold text-nowrap mb-2 mb-sm-0">RÉACTION PNJ :</span>
                                        <div class="d-flex align-items-center mb-2 mb-sm-0" style="width: auto; gap: 1.5rem;">
                                            <select id="pnjDiff" class="form-select form-select-sm border-secondary text-white rounded" style="background:#2c3034;">
                                                <option value="5">Offensif (Diff 5)</option>
                                                <option value="7" selected>Actif (Diff 7)</option>
                                                <option value="9">Passif (Diff 9)</option>
                                            </select>
                                            <button class="btn btn-sm btn-outline-info px-4 rounded" onclick="rollPNJInitiative()">
                                                <i class="fas fa-dice"></i> Lancer
                                            </button>
                                        </div>
                                    </div>
                                    <div>
                                        <button class="btn btn-sm btn-warning fw-bold text-dark px-3 py-2 shadow w-100" onclick="sortInitiative()">
                                            <i class="fas fa-sort-amount-down"></i> Appliquer l'Ordre
                                        </button>
                                    </div>
                                </div>
                            </div>
                            
                            <div id="combatListAll" class="d-flex flex-column gap-3 mb-4"></div>

                            <hr class="border-secondary mt-5">
                            <h5 class="text-white-50"><i class="fas fa-book-dead text-warning"></i> Boutiques & Bestiaire</h5>
                            <div class="row g-2 mb-3">
                                <div class="col-sm-8">
                                    <select id="bestiaryQuickSelect" class="form-select form-select-sm mj-select pe-4">
                                        <option value="">-- Choisir dans le Bestiaire --</option>
                                        {% for adv in adversaries %}
                                        <option value="{{ adv.name|escape('html') }}"
    data-react="{{ adv.reaction }}" 
    data-arm="{{ adv.armure }}" 
    data-l="{{ adv.blessuresLegeres }}" 
    data-g="{{ adv.blessuresGraves }}" 
    data-m="{{ adv.blessuresMortelles }}"
    data-atk="{{ adv.attaque|escape('html') }}"
    data-act="{{ adv.action|escape('html') }}"
    data-contact="{{ adv.contact|escape('html') }}"
    data-spec="{{ adv.specialite|escape('html') }}"
    data-specdet="{{ adv.specialite_details|escape('html') }}"
    data-rel="{{ adv.relances|escape('html') }}"
    data-res="{{ adv.reserve|escape('html') }}"
    data-arme="{{ adv.arme|escape('html') }}"
    data-cap="{{ adv.capacites|escape('html') }}"
    data-desc="{{ adv.description|escape('html') }}"
>{{ adv.name }} (Menace: {{ adv.menace }})</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-sm-4">
                                    <button class="btn btn-sm btn-warning w-100 fw-bold" onclick="generateBestiaryPNJ()"><i class="fas fa-plus"></i> Générer PNJ</button>
                                </div>
                            </div>
                            
                            <h5 class="text-white-50 mt-4"><i class="fas fa-user-edit text-info"></i> PNJ Rapide</h5>
                            <div class="row g-2 mb-3">
                                <div class="col-sm-12"><input type="text" id="neName" class="form-control form-control-sm border-secondary text-white" style="background:#222;" placeholder="Nom du PNJ (ex: Chasseur, Garde...)"></div>
                                <div class="col-sm-4">
                                    <select id="neMenace" class="form-select form-select-sm mj-select" title="Menace">
                                        <option value="Mineure">Mineure (3D)</option>
                                        <option value="Sérieuse" selected>Sérieuse (4D)</option>
                                        <option value="Majeure">Majeure (5D)</option>
                                        <option value="Mortelle">Mortelle (6D)</option>
                                        <option value="Funeste">Funeste (7D)</option>
                                        <option value="Effroyable">Effroyable (8D)</option>
                                    </select>
                                </div>
                                <div class="col-sm-4">
                                    <select id="neExp" class="form-select form-select-sm mj-select" title="Expérience">
                                        <option value="Débutant">Débutant (3D/4D)</option>
                                        <option value="Confirmé" selected>Confirmé (3D/5D)</option>
                                        <option value="Expert">Expert (4D/6D)</option>
                                        <option value="Maître">Maître (4D/6D)</option>
                                        <option value="Grand maître">Gd Maître (5D/7D)</option>
                                        <option value="Légende">Légende (6D/8D)</option>
                                    </select>
                                </div>
                                <div class="col-sm-4">
                                    <select id="neRole" class="form-select form-select-sm mj-select" title="Rôle">
                                        <option value="Mineur">Mineur</option>
                                        <option value="Secondaire" selected>Secondaire</option>
                                        <option value="Important">Important</option>
                                        <option value="Majeur">Majeur</option>
                                        <option value="Principal">Principal</option>
                                        <option value="Primordial">Primordial</option>
                                    </select>
                                </div>
                                <div class="col-sm-12"><input type="text" id="neSpecName" class="form-control form-control-sm border-secondary text-white" style="background:#222;" placeholder="Nom de la spécialité (ex: Archerie, Discrétion...)"></div>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary text-white w-100 mb-4" onclick="addEnemy()"><i class="fas fa-plus"></i> Générer par Profil</button>
                        </div>
                        
                        <!-- Panel de droite : Résolution Combat -->
                        <div class="col-md-5">
                            <h4>Résolution d'Attaque</h4>
                            
                            <div class="mb-3">
                                <label>Attaquant :</label>
                                <select id="atkAttaquant" class="form-select form-select-sm mj-select"></select>
                            </div>

                            <div class="mb-3">
                                <label>Réussites de l'attaquant (Jet d'Attaque) :</label>
                                <input type="number" id="atkJet" class="form-control form-control-sm" placeholder="Nb de réussites">
                            </div>
                            
                            <hr class="border-secondary">

                            <div class="mb-3">
                                <label>Cible :</label>
                                <select id="atkCible" class="form-select form-select-sm mj-select"></select>
                            </div>
                            
                            <div class="mb-3">
                                <label>Réussites du défenseur (Jet de Défense) :</label>
                                <input type="number" id="defJet" class="form-control form-control-sm" placeholder="Nb de réussites">
                            </div>
                            
                            <hr class="border-secondary">

                            <div class="mb-3">
                                <label>Arme & Dégâts de base (si touché) :</label>
                                <select id="atkArme" class="form-select form-select-sm mj-select mb-1">
                                    <option value="1D6,P">Arc - 1D6 (P)</option>
                                    <option value="1D6,T">Epée Courte - 1D6 (T)</option>
                                    <option value="2D6,T">Epée Lourde - 2D6 (T)</option>
                                    <option value="1D8,C">Masse - 1D8 (C)</option>
                                    <option value="1D4,C">Poings - 1D4 (C)</option>
                                    <option value="custom">Autre (Saisie Manuelle)</option>
                                </select>
                                <input type="text" id="atkArmeCustom" class="form-control form-control-sm" placeholder="Ex: 5" style="display:none;">
                                <input type="hidden" id="atkType" value="P">
                            </div>
                            
                            <button class="btn btn-danger w-100 mb-3" onclick="resolveAttack()"><i class="fas fa-gavel"></i> Lancer l'Attaque</button>
                            
                            <div id="combatLog" class="p-2 border border-secondary rounded" style="background:#111; height:300px; overflow-y:auto; font-family:monospace; font-size:0.9em; white-space:pre-wrap;"></div>
                            
                            <hr class="border-secondary mt-5 mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h4>Historique des Lancés (Joueurs)</h4>
                            </div>
                            <div class="dice-results d-flex flex-column border border-secondary rounded mb-4" style="height: 85vh; min-height: 800px; background-color: #1a1d24; box-shadow: inset 0 0 10px rgba(0,0,0,0.5);">
                                <div class="body-card p-3" style="flex: 1; overflow-y: auto; font-size: 0.9em; font-family: sans-serif; color: #eee;"></div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
    <div id="saveToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body">
          <i class="fas fa-check-circle me-2"></i> État du monde sauvegardé !
        </div>
      </div>
    </div>
</div>

<script>
// ----- JSON DATA DUMPS ----- //
const activeGroupeId = document.getElementById('activeGroupeId') ? document.getElementById('activeGroupeId').value : null;
const saveBtn = document.getElementById('saveWorldBtn');
const saveBtn2 = document.getElementById('saveWorldBtn2');
const toast = document.getElementById('saveToast');

document.addEventListener('DOMContentLoaded', () => {
    const saveChanges = async () => {
        const payload = {
            saison: document.getElementById('saison') ? document.getElementById('saison').value : null,
            climat: document.getElementById('climat') ? document.getElementById('climat').value : null,
            timeOfDay: document.getElementById('timeOfDay') ? document.getElementById('timeOfDay').value : null,
            weekType: document.getElementById('weekType') ? document.getElementById('weekType').value : null,
            dayNumber: document.getElementById('dayNumber') ? document.getElementById('dayNumber').value : null,
            sinlaPhase: document.getElementById('sinlaPhase') ? document.getElementById('sinlaPhase').value : null,
            akhatState: document.getElementById('akhatState') ? document.getElementById('akhatState').value : null,
            loisCoutumes: document.getElementById('loisCoutumes') ? document.getElementById('loisCoutumes').value : null,
            rations: document.getElementById('rations') ? document.getElementById('rations').value : null,
            etatMontures: document.getElementById('etatMontures') ? document.getElementById('etatMontures').value : null,
            encombrement: document.getElementById('encombrement') ? document.getElementById('encombrement').value : null,
            groupeId: activeGroupeId
        };
        try {
            const response = await fetch('/admin/world-state', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if(response.ok) {
                toast.style.display = 'block';
                setTimeout(() => { toast.style.opacity = '1'; }, 10);
                setTimeout(() => {
                    toast.style.opacity = '0';
                    setTimeout(() => { toast.style.display = 'none'; }, 400);
                }, 3000);
            } else {
                alert("Erreur lors de la sauvegarde.");
            }
        } catch(err) {
            console.error(err);
        }
    };
    if (saveBtn) saveBtn.addEventListener('click', saveChanges);
    if (saveBtn2) saveBtn2.addEventListener('click', saveChanges);
});

// ----- GESTION DE COMBAT ----- //
const PC_DATA = {{ characters|json_encode()|raw }};
const EQ_DATA = {{ equipment|json_encode()|raw }};

let combatants = [];

document.addEventListener('DOMContentLoaded', () => {
    // Initialiser les combatants PCs
    PC_DATA.forEach(pc => {
        let reaction = (pc.reflexes || 0) + (pc.vigilance || 0);
        let maxL = pc.maxblessurelegere || 4;
        let maxG = pc.maxblessuregrave || 2;
        let maxM = pc.maxblessuremortelle || 1;
        
        let l = pc.blessurelegere || 0;
        let g = pc.blessuregrave || 0;
        let m = pc.blessuremortelle || 0;
        
        let armorDesc = "0,0,0"; // Default (C,P,T)
        if(pc.armureEquipee) {
            let eq = EQ_DATA.find(e => e.name === pc.armureEquipee);
            if(eq && eq.stats) {
                const match = eq.stats.match(/Protection: (\d+)\((.*?)\)\/(\d+)\((.*?)\)\/(\d+)\((.*?)\)/);
                if(match) {
                    armorDesc = match[1]+","+match[3]+","+match[5];
                }
            }
        }
        
        combatants.push({
            id: pc.id_Character,
            isPC: true,
            name: pc.nom || "Inconnu",
            reaction: reaction,
            init: 0,
            armor: armorDesc,
            lMax: maxL,
            gMax: maxG,
            mMax: maxM,
            l: l,
            g: g,
            m: m
        });
    });
    
    let savedState = [];
    try {
        let raw = localStorage.getItem('combatantsState');
        if (raw) savedState = JSON.parse(raw);
    } catch(e) {}
    
    if (savedState && savedState.length > 0) {
        // Mettre à jour les PJ si trouvés dans le state
        combatants.forEach(pc => {
            let s = savedState.find(x => x.id === pc.id);
            if (s) {
                pc.init = s.init;
                pc.armor = s.armor;
                pc.l = s.l;
                pc.g = s.g;
                pc.m = s.m;
                pc.lMax = s.lMax;
                pc.gMax = s.gMax;
                pc.mMax = s.mMax;
            }
        });
        
        // Ajouter les PNJ du state
        let savedNPCs = savedState.filter(s => !s.isPC);
        combatants.push(...savedNPCs);
        
        // Trier par initiative
        combatants.sort((a,b) => b.init - a.init);
    }
    
    updateCombatUI();
});

function getArmorVal(armorStr, type) {
    if(!armorStr) return 0;
    let parts = armorStr.split(',');
    if(parts.length < 3) return parseInt(parts[0])||0;
    if(type === "C") return parseInt(parts[0])||0;
    if(type === "P") return parseInt(parts[1])||0;
    if(type === "T") return parseInt(parts[2])||0;
    return parseInt(parts[0])||0;
}

function addEnemy() {
    const name = document.getElementById("neName").value || "PNJ";
    const valMenace = document.getElementById("neMenace").value;
    const valExp = document.getElementById("neExp").value;
    const valRole = document.getElementById("neRole").value;
    const valSpecName = document.getElementById("neSpecName") ? document.getElementById("neSpecName").value : "";

    const tableMenace = {
        "Mineure": { atk: "3D", l: 1, g: 1, m: 1 },
        "Sérieuse": { atk: "4D", l: 2, g: 1, m: 1 },
        "Majeure": { atk: "5D", l: 2, g: 2, m: 1 },
        "Mortelle": { atk: "6D", l: 3, g: 2, m: 2 },
        "Funeste": { atk: "7D", l: 4, g: 3, m: 2 },
        "Effroyable": { atk: "8D", l: 5, g: 4, m: 2 }
    };
    
    const tableExp = {
        "Débutant": { act: "3D", spec: "4D", rel: "0D", contact: "7" },
        "Confirmé": { act: "3D", spec: "5D", rel: "0D", contact: "5" },
        "Expert": { act: "4D", spec: "6D", rel: "1D", contact: "7" },
        "Maître": { act: "4D", spec: "6D", rel: "2D", contact: "5" },
        "Grand maître": { act: "5D", spec: "7D", rel: "3D", contact: "5" },
        "Légende": { act: "6D", spec: "8D", rel: "4D", contact: "3" }
    };
    
    const tableRole = {
        "Mineur": { reactRaw: "3D", reserve: "0D", arm: 1 },
        "Secondaire": { reactRaw: "3D+1", reserve: "1D", arm: 2 },
        "Important": { reactRaw: "3D+2", reserve: "2D", arm: 2 },
        "Majeur": { reactRaw: "4D+2", reserve: "4D", arm: 3 },
        "Principal": { reactRaw: "4D+3", reserve: "6D", arm: 4 },
        "Primordial": { reactRaw: "5D+3", reserve: "8D", arm: 5 }
    };

    const m = tableMenace[valMenace];
    const e = tableExp[valExp];
    const r = tableRole[valRole];

    let reactMatch = r.reactRaw.match(/(\d+)/);
    let reactVal = reactMatch ? parseInt(reactMatch[1]) : 3;

    let npcData = {
        atk: m.atk,
        act: e.act,
        contact: e.contact,
        spec: e.spec,
        specdet: valSpecName,
        rel: e.rel,
        res: r.reserve,
        arme: "",
        cap: `Profil Rapide (${valMenace}, ${valExp}, ${valRole})`,
        desc: "",
        reactRaw: r.reactRaw,
        armRaw: String(r.arm),
        lRaw: String(m.l),
        gRaw: String(m.g),
        mRaw: String(m.m)
    };

    combatants.push({
        id: "npc_"+Date.now(),
        isPC: false,
        name: name,
        reaction: reactVal, // this sets the reaction logic to base number of dice for backwards compat
        init: 0,
        armor: r.arm + "," + r.arm + "," + r.arm,
        lMax: m.l,
        gMax: m.g,
        mMax: m.m,
        l: 0,
        g: 0,
        m: 0,
        npcData: npcData
    });
    updateCombatUI();
}

function clearCombatants() {
    combatants = combatants.filter(c => c.isPC);
    logAction("=> PNJ balayés du traqueur.");
    updateCombatUI();
}

function rollPNJInitiative() {
    let diff = parseInt(document.getElementById("pnjDiff").value);
    let count = 0;
    combatants.forEach(c => {
        if (!c.isPC) {
            let successes = 0;
            // Gestion du format 4D+2
            let rawReact = (c.npcData && c.npcData.reactRaw) ? c.npcData.reactRaw : String(c.reaction);
            let reactStr = rawReact.toString().toUpperCase().replace(/\s/g, '');
            let diceCount = parseInt(reactStr) || 2;
            let auto = reactStr.includes('+') ? (parseInt(reactStr.split('+')[1]) || 0) : 0;
            
            successes += auto;
            let rolls = [];
            for(let i=0; i<diceCount; i++){
                let r = Math.floor(Math.random() * 10) + 1;
                rolls.push(r);
                if (r >= diff) successes++;
            }
            c.init = successes;
            count++;
            
            let autoMs = auto > 0 ? ` (+${auto} bonus)` : "";
            logAction(`=> 🎲 Jet PNJ [${c.name}]: ${diceCount}D10 vs ${diff}${autoMs} -> [${rolls.join(', ')}] = ${successes} réussite(s)`);
        }
    });
    if(count > 0) logAction("=> 🎲 <b>Jets de Réaction PNJ terminés.</b> Cliquez sur 'Appliquer l'Ordre' pour trier timeline.");
    updateCombatUI();
}

function sortInitiative() {
    combatants.sort((a,b) => {
        if(a.init === b.init) {
            if(a.isPC && !b.isPC) return -1;
            if(!a.isPC && b.isPC) return 1;
            return 0; 
        }
        return b.init - a.init;
    });
    logAction("=> ⏱️ <b>Ordre d'Action appliqué !</b> (Egalités : PJs gagnent).");
    updateCombatUI();
}

function removeCombatant(id) {
    combatants = combatants.filter(c => c.id !== id);
    updateCombatUI();
}

