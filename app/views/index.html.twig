             <div class="form-group">
                 <label>Stats</label>
                 <input type="text" id="custom-item-stats" class="form-control">
             </div>
             <div class="form-group">
                 <label>Description</label>
                 <textarea id="custom-item-desc" class="form-control" rows="2"></textarea>
             </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="button" class="btn btn-primary" id="btn-save-item">Ajouter</button>
      </div>
    </div>
  </div>
</div>

