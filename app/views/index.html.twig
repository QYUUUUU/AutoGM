{% extends '/layouts/base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    	<link rel="stylesheet" href="/css/dashboard.css">
{% endblock %}



{% block body %}
<div class="row h-100 w-100">
    <div class="col-12 col-lg-3">
        <div class="flex-column h-100">
            <div class="conversations">
                <div class="head-card">
                    Options
                </div>
                <div class="body-card">
                    Select a Character : 
                    <select id="favoriteCharacter" class="select">
                    {% for character in characters %}
                        <option value="{{ character.id_Character }}">{{ character.nom }}</h2>
                    {% endfor %}
                    </select>
                    <div class="row align-items-center justify-content-center">
                        <div class="d4">
                            <label for="d4">d4:</label>
                            <button type="button" onclick="updateDiceInput('d4', 'add')">+</button>
                            <button type="button" onclick="updateDiceInput('d4', 'remove')">-</button><br><br>
                        </div>
                        <div class="d6">
                            <label for="d6">d6:</label>
                            <button type="button" onclick="updateDiceInput('d6', 'add')">+</button>
                            <button type="button" onclick="updateDiceInput('d6', 'remove')">-</button><br><br>
                        </div>
                    </div>
                    <div class="row align-items-center justify-content-center">
                        <div class="d10">
                            <label for="d10">d10:</label>
                            <button type="button" onclick="updateDiceInput('d10', 'add')">+</button>
                            <button type="button" onclick="updateDiceInput('d10', 'remove')">-</button><br><br>
                        </div>
                        <div class="d20">
                            <label for="d20">d20:</label>
                            <button type="button" onclick="updateDiceInput('d20', 'add')">+</button>
                            <button type="button" onclick="updateDiceInput('d20', 'remove')">-</button><br><br>
                        </div>
                    </div>
                    <label for="dice-input">Lancer les dés :</label>
                    <input type="text" id="dice-input" name="dice-input">

                    <input id="dice-throw-trigger" type="submit" value="Lancer les dés">
                </div>
            </div>
            <div class="dice-throws">
                <div class="head-card">
                    Mes dés
                </div>
                <div class="body-card">
                    <div id="ThreeJS"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="inventory">
            <div class="head-card">
                Notes
            </div>
            <div class="body-card">
                <div class="background-quill">
                    <div id="editor">
                        <p>Hello World!</p>
                        <p>Some initial
                            <strong>bold</strong>
                            text</p>
                        <p><br></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <div class="flex-column h-100">
            <div class="ask-dices">
                <div class="head-card">
                    Assistant
                </div>
                <div class="body-card">
                    <script type="module" src="js/user.js"></script>
                    <div class="card-body chat-body"></div>
                    <div id="error" class="error"></div>
                    <div id="{{conversation.id}}" class="conversationid"></div>
                    <div class="chat-area">
                        <div class="container items-chat">
                            <div id="prompt-form" class="row align-items-center">
                                <div class="d-flex justify-content-between textarea-chat">
                                    <textarea id="prompt-field" class="form-control" style="flex:1;"
                                        placeholder="Écrire un message"></textarea>
                                    <button id="send" class="send-button btn btn-primary"></button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="dice-results">
                <div class="head-card">
                    Résultats
                </div>
                <div class="body-card">
                    Le corps
                </div>
            </div>
        </div>
    </div>
</div>

{# Librairies notes #}

<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="/js/dashboardQuill.js"></script>

{# Librairies dés #}
<script src="/js/bundle.js"></script>

{% endblock %}