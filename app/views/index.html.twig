{% extends '/layouts/base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    	<link rel="stylesheet" href="/css/dashboard.css">
{% endblock %}



{% block body %}
<div class="bg-slideshow">
    <div class="bg-slide img1"></div>
    <div class="bg-slide img2"></div>
    <div class="bg-slide img3"></div>
    <div class="bg-slide img4"></div>
</div>

<div class="container-fluid h-100 w-100 pt-3 pb-3 px-4" style="position: relative; z-index: 1;">
    <div class="row h-100">
    <div class="col-12 col-lg-3">
        <div class="flex-column h-100">
            <div class="options-panel d-flex flex-column h-100" style="margin-top: 43px;">
                <div class="head-card">
                    Options
                </div>
                <div class="body-card flex-fill" style="overflow: visible;">
                    <div class="options-section mb-4 pb-3 border-bottom">
                        <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size: 0.85rem; letter-spacing: 0.05em;">Personnage & Équipement</h6>
                        <div class="character-selection">
                            Select a Character : 
                            <select id="favoriteCharacter" class="select">
                            {% for character in characters %}
                                <option value="{{ character.id_Character }}">{{ character.nom }}</option>
                            {% endfor %}
                            </select>
                        </div>
                        <div class="equipment-selection" style="margin-top:15px; margin-bottom: 15px;">
                            <label>Arme Équipée:</label>
                            <select id="armeSelect" class="select" style="width: 100%;">
                                <option value="">-- Aucune --</option>
                                {% for item in equipmentList %}
                                    {% if item.type == 'Armes' or item.type == 'Armure et boucliers' or item.type == 'Armes de jet' %}
                                        <option value="{{ item.name }}" data-stats="{{ item.stats }}" data-desc="{{ item.desc }}">{{ item.name }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                            <div id="armeStats" style="font-size:0.85em; color:#888; margin-bottom:10px;"></div>

                            <label>Armure Équipée:</label>
                            <select id="armureSelect" class="select" style="width: 100%;">
                                <option value="">-- Aucune --</option>
                                {% for item in equipmentList %}
                                    {% if item.type == 'Armures' or item.type == 'Armure et boucliers' %}
                                        <option value="{{ item.name }}" data-stats="{{ item.stats }}" data-desc="{{ item.desc }}">{{ item.name }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                            <div id="armureStats" style="font-size:0.85em; color:#888; margin-bottom:10px;"></div>
                        </div>
                    </div>
                    <div class="options-section mb-4 pb-3 border-bottom">
                        <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size: 0.85rem; letter-spacing: 0.05em;">Lancer Libre</h6>
                        <div class="dice-increments">
                        <div class="row align-items-center justify-content-center">
                            <div class="d4">
                                <label for="d4">d4:</label>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d4', 'add')">+</button>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d4', 'remove')">-</button><br>
                            </div>
                            <div class="d6">
                                <label for="d6">d6:</label>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d6', 'add')">+</button>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d6', 'remove')">-</button><br>
                            </div>
                        </div>
                        <div class="row align-items-center justify-content-center second-increments">
                            <div class="d10">
                                <label for="d10">d10:</label>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d10', 'add')">+</button>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d10', 'remove')">-</button><br><br>
                            </div>
                            <div class="d20">
                                <label for="d20">d20:</label>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d20', 'add')">+</button>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d20', 'remove')">-</button><br><br>
                            </div>
                        </div>
                        <label for="dice-input">Lancer les dés :</label>
                        <input type="text" id="dice-input" name="dice-input">

                        <input id="dice-throw-trigger" type="submit" value="Lancer les dés">
                    </div>
                    </div>

                    <div class="options-section mb-3">
                        <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size: 0.85rem; letter-spacing: 0.05em;">Test de Compétence</h6>
                        <div class="dice-statistics">
                        <div class="input-field dropdown-container">
                            <label for="caracteristic-input">Caractéristique :</label>
                            <input type="text" id="caracteristic-input" placeholder="Start typing...">
                            <div id="caracteristic-dropdown" class="dropdown">
                                <a data-value="puissance" href="#">Puissance</a>
                                <a data-value="resistance" href="#">Résistance</a>
                                <a data-value="precision" href="#">Précision</a>
                                <a data-value="reflexes" href="#">Réflexes</a>
                                <a data-value="connaissance" href="#">Connaissance</a>
                                <a data-value="perception" href="#">Perception</a>
                                <a data-value="volonte" href="#">Volonte</a>
                                <a data-value="empathie" href="#">Empathie</a>
                            </div>
                        </div>
                        <br>
                        <div class="dropdown-container">
                            <label for="dropdown-input">Compétence :</label>
                            <input type="text" id="dropdown-input" placeholder="Start typing...">
                            <div id="dropdown" class="dropdown">
                                <a data-value="arts" href="#">Arts</a>
                                <a data-value="cite" href="#">Cite</a>
                                <a data-value="civilisations" href="#">Civilisations</a>
                                <a data-value="relationnel" href="#">Relationnel</a>
                                <a data-value="soins" href="#">Soins</a>
                                <a data-value="animalisme" href="#">Animalisme</a>
                                <a data-value="faune" href="#">Faune</a>
                                <a data-value="montures" href="#">Montures</a>
                                <a data-value="pistage" href="#">Pistage</a>
                                <a data-value="territoire" href="#">Territoire</a>
                                <a data-value="adresse" href="#">Adresse</a>
                                <a data-value="armurerie" href="#">Armurerie</a>
                                <a data-value="artisanat" href="#">Artisanat</a>
                                <a data-value="mecanisme" href="#">Mecanisme</a>
                                <a data-value="runes" href="#">Runes</a>
                                <a data-value="athletisme" href="#">Athletisme</a>
                                <a data-value="discretion" href="#">Discretion</a>
                                <a data-value="flore" href="#">Flore</a>
                                <a data-value="vigilance" href="#">Vigilance</a>
                                <a data-value="voyage" href="#">Voyage</a>
                                <a data-value="bouclier" href="#">Bouclier</a>
                                <a data-value="cac" href="#">Corps à Corps</a>
                                <a data-value="lancer" href="#">Lancer</a>
                                <a data-value="melee" href="#">Melee</a>
                                <a data-value="tir" href="#">Tir</a>
                                <a data-value="eclats" href="#">Eclats</a>
                                <a data-value="lunes" href="#">Lunes</a>
                                <a data-value="mythes" href="#">Mythes</a>
                                <a data-value="pantheons" href="#">Pantheons</a>
                                <a data-value="rituels" href="#">Rituels</a>
                            </div>
                        </div>
                       <div class="row no-gutters">
                            <labell for="modifier">Modifier:</label>
                            <button id="increment" class="increment-button" type="button">+</button>
                            <input class="modifier" type="text" id="modifier" value="0">
                            <button id="decrement" class="increment-button" type="button">-</button><br>
                        </div>
                        <button id="stats-send" class="stats-send" type="button">Lancer les dés</button><br>
                    </div>
                </div>
                </div>
            </div>
            
        </div>
    </div>

    <div class="col-12 col-lg-9">
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <a class="nav-link active" id="results-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#results-tab-pane" href="#results-tab-pane" role="tab" aria-controls="results-tab-pane" aria-selected="true" style="font-weight: bold;">Résultats</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" id="assistant-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#assistant-tab-pane" href="#assistant-tab-pane" role="tab" aria-controls="assistant-tab-pane" aria-selected="false" style="font-weight: bold;">Interactions</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" id="groupe-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#groupe-tab-pane" href="#groupe-tab-pane" role="tab" aria-controls="groupe-tab-pane" aria-selected="false" style="font-weight: bold;">Groupe</a>
            </li>
        </ul>
        <div class="tab-content h-100" id="myTabContent" style="padding-top: 0;">
            <!-- tab résultats -->
            <div class="tab-pane fade show active h-100" id="results-tab-pane" role="tabpanel" aria-labelledby="results-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-md-6 h-100 pr-2 pl-0">
                        <div class="d-flex flex-column h-100">
                        <div class="dice-results mb-3 d-flex flex-column" style="flex: 1; min-height: 45vh; overflow: hidden;">
                            <div class="head-card square-tl">Résultats des dés</div>
                            <div class="body-card" style="flex: 1; min-height: 0; overflow-y: auto; padding-bottom: 20px;"></div>
                        </div>
<div class="inventory d-flex flex-column" style="flex: 1; min-height: 45vh; overflow: hidden;" data-inventory="{{ favoriteCharacter.character.inventory | e('html_attr') }}" data-char-id="{{ favoriteCharacter.character.id_Character }}">
                            <div class="head-card d-flex justify-content-between align-items-center">
                                <span>Inventaire</span>
                                <button class="btn btn-sm btn-outline-light" style="padding: 0 5px;" data-bs-toggle="modal" data-bs-target="#addItemModal">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                            <div class="body-card p-2" id="inventory-list" style="flex: 1; min-height: 0; overflow-y: auto;">
                                <!-- Item list will be injected here by JS -->
                            </div>
                        </div>

                        </div>
                    </div>
                    <div class="col-md-6 h-100 pl-2 pr-0">
                        <div class="d-flex flex-column h-100">
                        <div class="notes-container flex-fill d-flex flex-column h-100" style="min-height: 250px;">
                            <div class="head-card square-tr">Notes</div>
                            <div class="body-card p-0" style="flex: 1; min-height: 0; overflow-y: auto;">
                                <div class="background-quill h-100">
                                    <div id="editor" style="height: 100%;">
                                        <p>Hello World!</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        </div>
                    </div>
                </div>
            </div>

            <!-- tab assistant -->
            <div class="tab-pane fade h-100" id="assistant-tab-pane" role="tabpanel" aria-labelledby="assistant-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-md-6 h-100 pr-2 pl-0 d-none">
                        <div class="ask-dices h-100 flex-column d-flex">
                            <div class="head-card square-tl">Assistant (Lancé de Dés)</div>
                            <div class="body-card flex-fill d-flex flex-column">
                                <script type="module" src="js/user.js"></script>
                                <div class="card-body chat-body flex-fill" style="overflow-y: auto;"></div>
                                <div id="error" class="error"></div>
                                <div id="{{conversation.id}}" class="conversationid"></div>
                                <div class="chat-area mt-2">
                                    <div class="container items-chat px-0">
                                        <div id="prompt-form" class="row align-items-center mx-0 p-1 border shadow-sm" style="border-radius: 25px; background-color: #fff; margin-bottom: 5px;">
                                            <div class="d-flex w-100 p-0 align-items-center">
                                                <textarea id="prompt-field" class="form-control border-0 shadow-none m-0 p-2 overflow-hidden" rows="1" style="resize: none; background: transparent; outline: none; border-radius: 25px 0 0 25px;" placeholder="Écrire un message..."></textarea>
                                                <button id="send" class="btn btn-dark rounded-circle border-0 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; min-width: 40px; margin-left: 8px;"><i class="fas fa-paper-plane" style="margin-left: -1px;"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12 h-100 px-0">
                        <div class="ask-rules h-100 flex-column d-flex">
                            <div class="head-card square-tr square-tl">Questions de Règles</div>
                            <div class="body-card flex-fill d-flex flex-column">
                                <script type="module" src="js/rules_user.js"></script>
                                <div class="card-body chat-body-rules flex-fill" style="overflow-y: auto;"></div>
                                <div id="error-rules" class="error"></div>
                                <div id="{{conversation.id}}" class="conversationid-rules"></div>
                                <div class="chat-area mt-2">
                                    <div class="container items-chat px-0">
                                        <div id="prompt-form-rules" class="row align-items-center mx-0 p-1 border shadow-sm" style="border-radius: 25px; background-color: #fff; margin-bottom: 5px;">
                                            <div class="d-flex w-100 p-0 align-items-center">
                                                <textarea id="prompt-field-rules" class="form-control border-0 shadow-none m-0 p-2 overflow-hidden" rows="1" style="resize: none; background: transparent; outline: none; border-radius: 25px 0 0 25px;" placeholder="Posez vos questions sur les règles..."></textarea>
                                                <button id="send-rules" class="btn btn-dark rounded-circle border-0 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; min-width: 40px; margin-left: 8px;"><i class="fas fa-paper-plane" style="margin-left: -1px;"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- tab groupe -->
            <div class="tab-pane fade h-100" id="groupe-tab-pane" role="tabpanel" aria-labelledby="groupe-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-12 h-100 px-0">
                        <div class="head-card square-tl square-tr">Groupe</div>
                        <div class="body-card p-3" style="height: 100%; overflow-y: auto;">
                            {% if favoriteCharacter.character.Groupe is defined and favoriteCharacter.character.Groupe %}
                                <!-- The user is IN a group -->
                                <h4>{{ favoriteCharacter.character.Groupe.nom }}</h4>
                                <hr>
                                <div class="row mb-3">
                                    <div class="col-md-4 text-center">
                                        <div class="badge bg-dark border border-secondary text-light w-100 fs-6 p-2">Niveau {{ favoriteCharacter.character.Groupe.niveau }}</div>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <div class="badge bg-dark border border-secondary text-light w-100 fs-6 p-2">Réputation: {{ favoriteCharacter.character.Groupe.reputation }}</div>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <div class="badge bg-dark border border-secondary text-light w-100 fs-6 p-2" id="groupe-dice-display" data-grp-id="{{ favoriteCharacter.character.Groupe.id }}" data-grp-niveau="{{ favoriteCharacter.character.Groupe.niveau }}">
                                            Dés: {{ favoriteCharacter.character.Groupe.reserveDes }} / 
                                            {% if favoriteCharacter.character.Groupe.niveau == 1 %}12{% elseif favoriteCharacter.character.Groupe.niveau == 2 %}14{% else %}16{% endif %}
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-4 d-flex justify-content-evenly mt-3">
                                    <button class="btn btn-success px-4 py-2 fw-bold" onclick="ajouterDesGroupe({{ favoriteCharacter.character.Groupe.id }}, {{ favoriteCharacter.character.Groupe.niveau }})">Ajouter 1 Dé</button>
                                    <button class="btn btn-danger px-4 py-2 fw-bold" onclick="depenserDesGroupe({{ favoriteCharacter.character.Groupe.id }})">Dépenser 1 Dé</button>
                                </div>
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h5 class="m-0">Instinct: <span id="current-instinct-name">{{ favoriteCharacter.character.Groupe.instinctGroupe }}</span></h5>
                                    </div>
                                    <div class="p-3 bg-dark border border-secondary rounded text-light" id="current-instinct-details">
                                        <p><em>{{ favoriteCharacter.character.Groupe.capacitesInstinctGroupe }}</em></p>
                                    </div>
                                </div>
                                
                                <div class="mb-3 mt-4 text-light p-3 border border-secondary rounded bg-dark">
                                    <h5 class="text-light border-bottom border-secondary pb-2"><i class="fas fa-book"></i> Règles : Perdre et Regagner des Dés de Réserve de Groupe</h5>
                                    
                                    <div class="row">
                                      <div class="col-md-6">
                                        <!-- title --><h6 class="text-danger mt-2">Dépenses & Pertes</h6>
                                        <ul class="small mb-0" style="list-style-type: none; padding-left: 0;">
                                            <li><span class="text-danger fw-bold">-1D</span> : Tension mineure (brouille, désaccord), ou Découragement (fatigue, faim, soif)</li>
                                            <li><span class="text-danger fw-bold">-2D à -3D</span> : Coup dur (vol, perte d'équipement, mauvaise nouvelle)</li>
                                            <li><span class="text-danger fw-bold">-3D</span> : Tension majeure (conflit, accusation grave)</li>
                                            <li><span class="text-danger fw-bold">-3D à -5D</span> : Interdit de l'Instinct enfreint</li>
                                            <li><span class="text-danger fw-bold">-5D</span> : Choc (mort d'un membre, trahison)</li>
                                        </ul>
                                      </div>
                                      <div class="col-md-6">
                                        <!-- title --><h6 class="text-success mt-2">Gains de Dés</h6>
                                        <ul class="small mb-0" style="list-style-type: none; padding-left: 0;">
                                            <li><span class="text-success fw-bold">+1D</span> : Bon moment partagé (repas, échange)</li>
                                            <li><span class="text-success fw-bold">+1D à +2D</span> : Cohésion (action collective, esprit d'équipe)</li>
                                            <li><span class="text-success fw-bold">+2D à +3D</span> : Communauté (réussite collective, harmonie)</li>
                                            <li><span class="text-success fw-bold">+3D à +5D</span> : Principe de l'Instinct accompli</li>
                                            <li><span class="text-success fw-bold">+5D à Max</span> : Accomplissement (Objectif majeur)</li>
                                        </ul>
                                      </div>
                                    </div>
                                    <p class="small text-muted mt-3 mb-0"><em>Note: Les principes et interdits suivis d'un astérisque (*) peuvent faire gagner ou perdre jusqu'à 4D dans chacune des Réserves s'ils sont significatifs pour le Groupe.</em></p>
                                </div>
                                <div class="mb-3">
                                    <h5>Capacités de Groupe:</h5>
                                    <ul>
                                        <li><strong>Unité:</strong> +1D aux actions collectives</li>
                                        <li><strong>Expertise partagée:</strong> +1 réussite si un membre du groupe possède la compétence (Expert)</li>
                                        <li>{{ favoriteCharacter.character.Groupe.capacitesGroupe }}</li>
                                    </ul>
                                </div>
                                <div class="text-end mt-4 mb-2">
                                    <!-- Quitter button --><button style="color: #d9534f; text-decoration: underline; background: none; border: none; padding: 0; font-size: 0.9em; cursor: pointer;" onmouseover="this.style.color='#ff6b6b'" onmouseout="this.style.color='#d9534f'" onclick="quitterGroupe({{ favoriteCharacter.character.id_Character }})">Quitter le groupe</button>
                                </div>
                            {% else %}
                                <!-- The user is NOT in a group -->
                                <p>Rejoignez un groupe existant ou créez-en un nouveau.</p>

                                <h5>Rejoindre un groupe</h5>
                                <div class="d-flex mb-4">
                                    <select class="form-select me-2" id="group-select" style="min-width: 200px;">
                                        {% if allGroupes is defined and allGroupes|length > 0 %}
                                            {% for grp in allGroupes %}
                                                <option value="{{ grp.id }}">{{ grp.nom }} (Niveau {{ grp.niveau }})</option>
                                            {% endfor %}
                                        {% else %}
                                            <option value="">Aucun groupe disponible</option>
                                        {% endif %}
                                    </select>
                                    <button class="btn btn-success" onclick="rejoindreGroupe({{ favoriteCharacter.character.id_Character }})">Rejoindre</button>
                                </div>

                                <hr>

                                <h5>Créer un groupe</h5>
                                <form id="create-group-form">
                                    <div class="mb-2">
                                        <label>Nom du Groupe</label>
                                        <input type="text" class="form-control bg-dark text-light border-secondary" id="new-group-name" required>
                                    </div>
                                    <div class="mb-2">
                                        <label>Instinct du Groupe</label>
                                        <select class="form-select bg-dark text-light border-secondary" id="new-group-instinct" required>
                                            <option value="architecte">L’Architecte</option>
                                            <option value="epee">L’Épée</option>
                                            <option value="fleau">Le Fléau</option>
                                            <option value="gardien">Le Gardien</option>
                                            <option value="homme">L’Homme</option>
                                            <option value="main">La Main</option>
                                            <option value="masque">Le Masque</option>
                                            <option value="neant">Le Néant</option>
                                            <option value="os">L’Os</option>
                                            <option value="voyageur">Le Voyageur</option>
                                        </select>
                                    </div>
                                    <div id="groupInstinctDescriptionBlock" class="p-2 mb-2 bg-secondary text-light rounded" style="display: none;">
                                        <h6 id="groupInstinctTitle" class="mb-1 fw-bold"></h6>
                                        <p id="groupInstinctText" class="mb-1 small" style="font-style: italic;"></p>
                                        <div id="groupInstinctStats" class="small text-warning" style="border-top: 1px solid #666; padding-top: 5px; margin-top: 5px;"></div>
                                    </div>
                                    <button type="button" class="btn btn-success mt-2" onclick="creerGroupe({{ favoriteCharacter.character.id_Character }})">Créer</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>
<!-- Add Item Modal -->
<div class="modal fade" id="addItemModal" tabindex="-1" role="dialog" aria-labelledby="addItemModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content text-dark">
      <div class="modal-header">
        <h5 class="modal-title" id="addItemModalLabel">Ajouter un objet</h5>
        <button type="button" class="close btn btn-link" data-bs-dismiss="modal" aria-label="Close" style="color: black; text-decoration: none; font-size: 1.5rem;">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <ul class="nav nav-tabs" id="itemTabs" role="tablist">
          <li class="nav-item">
            <a class="nav-link active" id="premade-item-tab" data-bs-toggle="tab" href="#premade-item" role="tab">Dans le manuel</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="custom-item-tab" data-bs-toggle="tab" href="#custom-item" role="tab">Objet personnalisé</a>
          </li>
        </ul>
        <div class="tab-content mt-3" id="itemTabsContent">
          <!-- Premade Item -->
          <div class="tab-pane fade show active" id="premade-item" role="tabpanel">
             <div class="form-group">
                <label for="item-select">Sélectionner un objet</label>
                <select id="item-select" class="form-control">
                    <option value="">Sélectionnez...</option>
                    {% for item in equipmentList %}
                        <option value="{{ loop.index0 }}" 
                                data-name="{{ item.name }}" 
                                data-type="{{ item.type }}" 
                                data-stats="{{ item.stats }}" 
                                data-desc="{{ item.desc }}">
                            {{ item.name }} ({{ item.type }}) - {{ item.price }} Or - Rareté {{ item.rarity }}
                        </option>
                    {% endfor %}
                </select>
             </div>
          </div>
          <!-- Custom Item -->
          <div class="tab-pane fade" id="custom-item" role="tabpanel">
             <div class="form-group">
                 <label>Nom</label>
                 <input type="text" id="custom-item-name" class="form-control">
             </div>
             <div class="form-group">
                 <label>Type</label>
                 <input type="text" id="custom-item-type" class="form-control" placeholder="Arme, Armure, Consommable...">
             </div>
             <div class="form-group">
                 <label>Stats</label>
                 <input type="text" id="custom-item-stats" class="form-control">
             </div>
             <div class="form-group">
                 <label>Description</label>
                 <textarea id="custom-item-desc" class="form-control" rows="2"></textarea>
             </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <button type="button" class="btn btn-primary" id="btn-save-item">Ajouter</button>
      </div>
    </div>
  </div>
</div>

<div id="ThreeJS" style="position: fixed; top: 0; left: 0; pointer-events: none; z-index: 1000; width: 100vw; height: 100vh;"></div>

