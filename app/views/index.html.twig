{% extends '/layouts/base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    	<link rel="stylesheet" href="/css/dashboard.css">
{% endblock %}



{% block body %}
<div class="bg-slideshow">
    <div class="bg-slide img1"></div>
    <div class="bg-slide img2"></div>
    <div class="bg-slide img3"></div>
    <div class="bg-slide img4"></div>
</div>

<div class="container-fluid h-100 w-100 pt-3 pb-3 px-4" style="position: relative; z-index: 1;">
    <div class="row h-100">
    <div class="col-12 col-lg-3">
        <div class="flex-column h-100">
            <div class="options-panel d-flex flex-column h-100" style="margin-top: 43px;">
                <div class="head-card">
                    Options
                </div>
                <div class="body-card flex-fill" style="overflow: visible;">
                    <div class="options-section mb-4 pb-3 border-bottom">
                        <h6 class="fw-bold text-light text-uppercase mb-3" style="font-size: 0.85rem; letter-spacing: 0.05em;">Test de Compétence</h6>
                        <div class="dice-statistics">
                        <div class="input-field dropdown-container">
                            <label for="caracteristic-input">Caractéristique :</label>
                            <input type="text" id="caracteristic-input" placeholder="Start typing...">
                            <div id="caracteristic-dropdown" class="dropdown">
                                <a data-value="puissance" href="#">Puissance</a>
                                <a data-value="resistance" href="#">Résistance</a>
                                <a data-value="precision" href="#">Précision</a>
                                <a data-value="reflexes" href="#">Réflexes</a>
                                <a data-value="connaissance" href="#">Connaissance</a>
                                <a data-value="perception" href="#">Perception</a>
                                <a data-value="volonte" href="#">Volonte</a>
                                <a data-value="empathie" href="#">Empathie</a>
                            </div>
                        </div>
                        <br>
                        <div class="dropdown-container">
                            <label for="dropdown-input">Compétence :</label>
                            <input type="text" id="dropdown-input" placeholder="Start typing...">
                            <div id="dropdown" class="dropdown">
                                <a data-value="arts" href="#">Arts</a>
                                <a data-value="cite" href="#">Cite</a>
                                <a data-value="civilisations" href="#">Civilisations</a>
                                <a data-value="relationnel" href="#">Relationnel</a>
                                <a data-value="soins" href="#">Soins</a>
                                <a data-value="animalisme" href="#">Animalisme</a>
                                <a data-value="faune" href="#">Faune</a>
                                <a data-value="montures" href="#">Montures</a>
                                <a data-value="pistage" href="#">Pistage</a>
                                <a data-value="territoire" href="#">Territoire</a>
                                <a data-value="adresse" href="#">Adresse</a>
                                <a data-value="armurerie" href="#">Armurerie</a>
                                <a data-value="artisanat" href="#">Artisanat</a>
                                <a data-value="mecanisme" href="#">Mecanisme</a>
                                <a data-value="runes" href="#">Runes</a>
                                <a data-value="athletisme" href="#">Athletisme</a>
                                <a data-value="discretion" href="#">Discretion</a>
                                <a data-value="flore" href="#">Flore</a>
                                <a data-value="vigilance" href="#">Vigilance</a>
                                <a data-value="voyage" href="#">Voyage</a>
                                <a data-value="bouclier" href="#">Bouclier</a>
                                <a data-value="cac" href="#">Corps à Corps</a>
                                <a data-value="lancer" href="#">Lancer</a>
                                <a data-value="melee" href="#">Melee</a>
                                <a data-value="tir" href="#">Tir</a>
                                <a data-value="eclats" href="#">Eclats</a>
                                <a data-value="lunes" href="#">Lunes</a>
                                <a data-value="mythes" href="#">Mythes</a>
                                <a data-value="pantheons" href="#">Pantheons</a>
                                <a data-value="rituels" href="#">Rituels</a>
                            </div>
                        </div>
                       <div class="row no-gutters">
                            <labell for="modifier">Modifier:</label>
                            <button id="increment" class="increment-button" type="button">+</button>
                            <input class="modifier" type="text" id="modifier" value="0">
                            <button id="decrement" class="increment-button" type="button">-</button><br>
                        </div>
                        <div>
                            <input type="checkbox" id="isCollective-action" name="isCollective-action">
                            <label for="isCollective-action">Action Collective</label>
                        </div>
                        <button id="stats-send" class="stats-send" type="button">Lancer les dés</button><br>
                    </div>
                </div>

                    <div class="options-section mb-4 pb-3 border-bottom">
                        <h6 class="fw-bold text-light text-uppercase mb-3" style="font-size: 0.85rem; letter-spacing: 0.05em;">Lancer Libre</h6>
                        <div class="dice-increments">
                        <div class="row align-items-center justify-content-center">
                            <div class="d4">
                                <label for="d4">d4:</label>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d4', 'add')">+</button>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d4', 'remove')">-</button><br>
                            </div>
                            <div class="d6">
                                <label for="d6">d6:</label>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d6', 'add')">+</button>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d6', 'remove')">-</button><br>
                            </div>
                        </div>
                        <div class="row align-items-center justify-content-center second-increments">
                            <div class="d10">
                                <label for="d10">d10:</label>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d10', 'add')">+</button>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d10', 'remove')">-</button><br><br>
                            </div>
                            <div class="d20">
                                <label for="d20">d20:</label>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d20', 'add')">+</button>
                                <button class="increment-button" type="button" onclick="updateDiceInput('d20', 'remove')">-</button><br><br>
                            </div>
                        </div>
                        <label for="dice-input">Lancer les dés :</label>
                        <input type="text" id="dice-input" name="dice-input">
                        <input type="color" id="dice-color-picker" value="#2d2d2d" title="Couleur des dés" style="height: 30px; width: 30px; border: none; background: transparent; padding: 0; vertical-align: middle;">

                        <input id="dice-throw-trigger" type="submit" value="Lancer les dés">
                    </div>
                    </div>

                    <div class="options-section mb-3">
                        <h6 class="fw-bold text-light text-uppercase mb-3" style="font-size: 0.85rem; letter-spacing: 0.05em;">Personnage & Équipement</h6>
                        <div class="character-selection">
                            Select a Character : 
                            <select id="favoriteCharacter" class="select">
                            {% for character in characters %}
                                <option value="{{ character.id_Character }}">{{ character.nom }}</option>
                            {% endfor %}
                            </select>
                        </div>
                        <div class="equipment-selection" style="margin-top:15px; margin-bottom: 15px;">
                            <label>Arme Équipée:</label>
                            <select id="armeSelect" class="select" style="width: 100%;">
                                <option value="">-- Aucune --</option>
                                {% for item in equipmentList %}
                                    {% if item.type == 'Armes' or item.type == 'Armure et boucliers' or item.type == 'Armes de jet' %}
                                        <option value="{{ item.name }}" data-stats="{{ item.stats }}" data-desc="{{ item.desc }}">{{ item.name }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                            <div id="armeStats" style="font-size:0.85em; color:#888; margin-bottom:10px;"></div>

                            <label>Armure Équipée:</label>
                            <select id="armureSelect" class="select" style="width: 100%;">
                                <option value="">-- Aucune --</option>
                                {% for item in equipmentList %}
                                    {% if item.type == 'Armures' or item.type == 'Armure et boucliers' %}
                                        <option value="{{ item.name }}" data-stats="{{ item.stats }}" data-desc="{{ item.desc }}">{{ item.name }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                            <div id="armureStats" style="font-size:0.85em; color:#888; margin-bottom:10px;"></div>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>

    <div class="col-12 col-lg-9">
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <a class="nav-link active" id="results-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#results-tab-pane" href="#results-tab-pane" role="tab" aria-controls="results-tab-pane" aria-selected="true" style="font-weight: bold;">Résultats</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" id="assistant-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#assistant-tab-pane" href="#assistant-tab-pane" role="tab" aria-controls="assistant-tab-pane" aria-selected="false" style="font-weight: bold;">Interactions</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" id="groupe-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#groupe-tab-pane" href="#groupe-tab-pane" role="tab" aria-controls="groupe-tab-pane" aria-selected="false" style="font-weight: bold;">Groupe</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" id="capacites-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#capacites-tab-pane" href="#capacites-tab-pane" role="tab" aria-controls="capacites-tab-pane" aria-selected="false" style="font-weight: bold;">Personnage</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" id="ressources-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#ressources-tab-pane" href="#ressources-tab-pane" role="tab" aria-controls="ressources-tab-pane" aria-selected="false" style="font-weight: bold;">Ressources</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" id="eclat-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#eclat-tab-pane" href="#eclat-tab-pane" role="tab" aria-controls="eclat-tab-pane" aria-selected="false" style="font-weight: bold;">Éclat</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" id="rituels-tab" data-bs-toggle="tab" data-toggle="tab" data-bs-target="#rituels-tab-pane" href="#rituels-tab-pane" role="tab" aria-controls="rituels-tab-pane" aria-selected="false" style="font-weight: bold;">Rituels</a>
            </li>
        </ul>
        <div class="tab-content h-100" id="myTabContent" style="padding-top: 0;">
            <!-- tab résultats -->
            <div class="tab-pane fade show active h-100" id="results-tab-pane" role="tabpanel" aria-labelledby="results-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-md-6 h-100 pr-2 pl-0">
                        <div class="d-flex flex-column h-100">
                        <div class="dice-results mb-3 d-flex flex-column" style="flex: 1; min-height: 45vh; overflow: hidden;">
                            <div class="head-card square-tl">Résultats des dés</div>
                            <div class="body-card" style="flex: 1; min-height: 0; overflow-y: auto; padding-bottom: 20px;"></div>
                        </div>
<div class="inventory d-flex flex-column" style="flex: 1; min-height: 45vh; overflow: hidden;" data-inventory="{{ favoriteCharacter.character.inventory | e('html_attr') }}" data-char-id="{{ favoriteCharacter.character.id_Character }}">
                            <div class="head-card d-flex justify-content-between align-items-center">
                                <span>Inventaire</span>
                                <button class="btn btn-sm btn-outline-light" style="padding: 0 5px;" data-bs-toggle="modal" data-bs-target="#addItemModal">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                            <div class="body-card p-2" id="inventory-list" style="flex: 1; min-height: 0; overflow-y: auto;">
                                <!-- Item list will be injected here by JS -->
                            </div>
                        </div>

                        </div>
                    </div>
                    <div class="col-md-6 h-100 pl-2 pr-0">
                        <div class="d-flex flex-column h-100">
                        <div class="notes-container flex-fill d-flex flex-column h-100" style="min-height: 250px;">
                            <div class="head-card square-tr">Notes</div>
                            <div class="body-card p-0" style="flex: 1; min-height: 0; overflow-y: auto;">
                                <div class="background-quill h-100">
                                    <div id="editor" style="height: 100%;">
                                        <p>Hello World!</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        </div>
                    </div>
                </div>
            </div>

            <!-- tab assistant -->
            <div class="tab-pane fade h-100" id="assistant-tab-pane" role="tabpanel" aria-labelledby="assistant-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-md-6 h-100 pr-2 pl-0 d-none">
                        <div class="ask-dices h-100 flex-column d-flex">
                            <div class="head-card square-tl">Assistant (Lancé de Dés)</div>
                            <div class="body-card flex-fill d-flex flex-column">
                                <script type="module" src="js/user.js"></script>
                                <div class="card-body chat-body flex-fill" style="overflow-y: auto;"></div>
                                <div id="error" class="error"></div>
                                <div id="{{conversation.id}}" class="conversationid"></div>
                                <div class="chat-area mt-2">
                                    <div class="container items-chat px-0">
                                        <div id="prompt-form" class="row align-items-center mx-0 p-1 border shadow-sm" style="border-radius: 25px; background-color: #fff; margin-bottom: 5px;">
                                            <div class="d-flex w-100 p-0 align-items-center">
                                                <textarea id="prompt-field" class="form-control border-0 shadow-none m-0 p-2 overflow-hidden" rows="1" style="resize: none; background: transparent; outline: none; border-radius: 25px 0 0 25px;" placeholder="Écrire un message..."></textarea>
                                                <button id="send" class="btn btn-dark rounded-circle border-0 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; min-width: 40px; margin-left: 8px;"><i class="fas fa-paper-plane" style="margin-left: -1px;"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12 h-100 px-0">
                        <div class="ask-rules h-100 flex-column d-flex">
                            <div class="head-card square-tr square-tl">Questions de Règles</div>
                            <div class="body-card flex-fill d-flex flex-column">
                                <script type="module" src="js/rules_user.js"></script>
                                <div class="card-body chat-body-rules flex-fill" style="overflow-y: auto;"></div>
                                <div id="error-rules" class="error"></div>
                                <div id="{{conversation.id}}" class="conversationid-rules"></div>
                                <div class="chat-area mt-2">
                                    <div class="container items-chat px-0">
                                        <div id="prompt-form-rules" class="row align-items-center mx-0 p-1 border shadow-sm" style="border-radius: 25px; background-color: #fff; margin-bottom: 5px;">
                                            <div class="d-flex w-100 p-0 align-items-center">
                                                <textarea id="prompt-field-rules" class="form-control border-0 shadow-none m-0 p-2 overflow-hidden" rows="1" style="resize: none; background: transparent; outline: none; border-radius: 25px 0 0 25px;" placeholder="Posez vos questions sur les règles..."></textarea>
                                                <button id="send-rules" class="btn btn-dark rounded-circle border-0 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; min-width: 40px; margin-left: 8px;"><i class="fas fa-paper-plane" style="margin-left: -1px;"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- tab capacites -->
            <div class="tab-pane fade h-100" id="capacites-tab-pane" role="tabpanel" aria-labelledby="capacites-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-12 h-100 px-0">
                        <div class="head-card square-tl square-tr">Modificateurs & Origine</div>
                        <div class="body-card p-4" style="height: 100%; overflow-y: auto;">
                            <h4 class="fw-bold mb-3"><i class="fas fa-paw"></i> Capacité d'Instinct</h4>
                            <div class="mb-4 p-3 bg-dark border border-secondary rounded text-light">
                                <h5 class="mb-1">Instinct : <span class="text-success" id="nom-instinct">{{ favoriteCharacter.character.instinct|default("Aucun instinct sélectionné") }}</span></h5>
                                <p id="desc-instinct" class="text-light  mb-3 fst-italic" style="border-bottom: 1px solid #444; padding-bottom: 10px;"></p>
                                
                                {% if favoriteCharacter.character.capaciteInstinct1 %}
                                <p class="mb-2"><strong><span id="nom-cap-1">{{ favoriteCharacter.character.capaciteInstinct1 }}</span>:</strong><br><span id="desc-cap-1" class="text-light "></span></p>
                                {% else %}
                                <p class="mb-2 text-light ">Aucune capacité d'instinct sélectionnée.</p>
                                {% endif %}
                                
                                
                            </div>
                            
                            <h4 class="fw-bold mt-5 mb-1"><i class="fas fa-globe"></i> Origine : <span class="text-warning" id="nom-origine">{{ favoriteCharacter.character.origine|default("Aucune") }}</span></h4>
                            <p id="desc-origine" class="text-light  mb-3 fst-italic text-light" style="padding-left: 10px;"></p>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <div class="p-3 bg-dark border border-secondary rounded text-light h-100">
                                        <h5 class="text-success border-bottom border-secondary pb-2"><i class="fas fa-plus-circle"></i> Avantage d'origine</h5>
                                        <p class="mb-0"><strong><span id="nom-avantage">{{ favoriteCharacter.character.avantage ? favoriteCharacter.character.avantage : 'Aucun avantage' }}</span></strong><br><span id="desc-avantage" class="text-light "></span></p>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="p-3 bg-dark border border-secondary rounded text-light h-100">
                                        <h5 class="text-danger border-bottom border-secondary pb-2"><i class="fas fa-minus-circle"></i> Désavantage d'origine</h5>
                                        <p class="mb-0"><strong><span id="nom-desavantage">{{ favoriteCharacter.character.desavantage ? favoriteCharacter.character.desavantage : 'Aucun désavantage' }}</span></strong><br><span id="desc-desavantage" class="text-light "></span></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            
            <!-- tab ressources -->
            <div class="tab-pane fade h-100" id="ressources-tab-pane" role="tabpanel" aria-labelledby="ressources-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-12 h-100 px-0">
                        <div class="head-card square-tl square-tr">Réserves & Savoir</div>
                        <div class="body-card p-4" style="height: 100%; overflow-y: auto;">
                            
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="p-3 bg-dark border border-secondary rounded text-light h-100">
                                        <h5 class="text-warning border-bottom border-secondary pb-2"><i class="fas fa-fist-raised"></i> Effort</h5>
                                        <div class="d-flex align-items-center justify-content-center gap-3 mt-3">
                                            <button class="btn btn-outline-danger px-3 py-1 fs-5 rounded-circle" onclick="updateRessource('effort', -1, {{ favoriteCharacter.character.id_Character }})"><i class="fas fa-minus"></i></button>
                                            <span id="display-effort" class="fs-2 fw-bold text-light mx-3">{{ favoriteCharacter.character.effort|default(15) }} / {{ favoriteCharacter.character.maxeffort|default(15) }}</span>
                                            <button class="btn btn-outline-success px-3 py-1 fs-5 rounded-circle" onclick="updateRessource('effort', 1, {{ favoriteCharacter.character.id_Character }})"><i class="fas fa-plus"></i></button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 bg-dark border border-secondary rounded text-light h-100">
                                        <h5 class="text-info border-bottom border-secondary pb-2"><i class="fas fa-brain"></i> Sang Froid</h5>
                                        <div class="d-flex align-items-center justify-content-center gap-3 mt-3">
                                            <button class="btn btn-outline-danger px-3 py-1 fs-5 rounded-circle" onclick="updateRessource('sangfroid', -1, {{ favoriteCharacter.character.id_Character }})"><i class="fas fa-minus"></i></button>
                                            <span id="display-sangfroid" class="fs-2 fw-bold text-light mx-3">{{ favoriteCharacter.character.sangfroid|default(8) }} / {{ favoriteCharacter.character.maxsangfroid|default(8) }}</span>
                                            <button class="btn btn-outline-success px-3 py-1 fs-5 rounded-circle" onclick="updateRessource('sangfroid', 1, {{ favoriteCharacter.character.id_Character }})"><i class="fas fa-plus"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ÉTAT DE SANTÉ -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <div class="p-3 bg-dark border border-secondary rounded text-light h-100">
                                        <h5 class="text-danger border-bottom border-secondary pb-2"><i class="fas fa-heartbeat"></i> État de Santé</h5>
                                        <div class="pt-3 row text-center">
                                            
                                            <div class="col-md-4 mb-3 mb-md-0">
                                                <h6 class="text-warning">Légères</h6>
                                                <div class="d-flex justify-content-center gap-1 mt-2">
                                                    {% set max_legere = favoriteCharacter.character.maxblessurelegere|default(5) %}
                                                    {% set curr_legere = favoriteCharacter.character.blessurelegere|default(0) %}
                                                    {% for i in 1..max_legere %}
                                                        {% set isRed = (i <= curr_legere) %}
                                                        <img src="{{ isRed ? '/images/circlered.png' : '/images/circle.png' }}" 
                                                             id="legere-dash{{ i }}" 
                                                             style="cursor: pointer; width: 28px; height: 28px;" 
                                                             onclick="updateBlessure('blessurelegere', {{ i }}, {{ favoriteCharacter.character.id_Character }})">
                                                    {% endfor %}
                                                </div>
                                            </div>

                                            <div class="col-md-4 mb-3 mb-md-0">
                                                <h6 style="color: #fd7e14;">Graves</h6>
                                                <div class="d-flex justify-content-center gap-1 mt-2">
                                                    {% set max_grave = favoriteCharacter.character.maxblessuregrave|default(3) %}
                                                    {% set curr_grave = favoriteCharacter.character.blessuregrave|default(0) %}
                                                    {% for i in 1..max_grave %}
                                                        {% set isRed = (i <= curr_grave) %}
                                                        <img src="{{ isRed ? '/images/circlered.png' : '/images/circle.png' }}" 
                                                             id="grave-dash{{ i }}" 
                                                             style="cursor: pointer; width: 28px; height: 28px;" 
                                                             onclick="updateBlessure('blessuregrave', {{ i }}, {{ favoriteCharacter.character.id_Character }})">
                                                    {% endfor %}
                                                </div>
                                            </div>

                                            <div class="col-md-4">
                                                <h6 class="text-danger">Mortelles</h6>
                                                <div class="d-flex justify-content-center gap-1 mt-2">
                                                    {% set max_mortelle = favoriteCharacter.character.maxblessuremortelle|default(2) %}
                                                    {% set curr_mortelle = favoriteCharacter.character.blessuremortelle|default(0) %}
                                                    {% for i in 1..max_mortelle %}
                                                        {% set isRed = (i <= curr_mortelle) %}
                                                        <img src="{{ isRed ? '/images/circlered.png' : '/images/circle.png' }}" 
                                                             id="mortelle-dash{{ i }}" 
                                                             style="cursor: pointer; width: 28px; height: 28px;" 
                                                             onclick="updateBlessure('blessuremortelle', {{ i }}, {{ favoriteCharacter.character.id_Character }})">
                                                    {% endfor %}
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>

                            
                            <!-- TECHNIQUES DE COMBAT -->
                            <div class="row mb-4">
                                <div class="col-12">
                                    <div class="p-3 bg-dark border border-secondary rounded text-light h-100">
                                        <h5 class="text-info border-bottom border-secondary pb-2"><i class="fas fa-khanda"></i> Techniques de Combat débloquées</h5>
                                        <div class="pt-2">
                                            {% set t_charge = false %}
                                            {% set t_att_precise = false %}
                                            {% set t_att_surprise = false %}
                                            {% set t_celerite = false %}
                                            {% set t_deux_armes = false %}
                                            {% set t_coup_bas = false %}
                                            {% set t_finesse = false %}
                                            {% set t_frappe_lourde = false %}
                                            {% set t_parade = false %}
                                            {% set t_polyvalence = false %}
                                            {% set t_protection = false %}
                                            {% set t_saisie = false %}
                                            {% set t_tir_instinctif = false %}
                                            {% set t_tir_precis = false %}
                                            {% set t_volee = false %}

                                            {% set melee = favoriteCharacter.character.melee|default(0) %}
                                            {% set cac = favoriteCharacter.character.cac|default(0) %}
                                            {% set tir = favoriteCharacter.character.tir|default(0) %}
                                            {% set lancer = favoriteCharacter.character.lancer|default(0) %}
                                            {% set bouclier = favoriteCharacter.character.bouclier|default(0) %}
                                            {% set discretion = favoriteCharacter.character.discretion|default(0) %}
                                            
                                            {% set puissance = favoriteCharacter.character.puissance|default(1) %}
                                            {% set precision = favoriteCharacter.character.precision|default(1) %}
                                            {% set reflexes = favoriteCharacter.character.reflexes|default(1) %}

                                            {% if (melee >= 3) and (precision >= 3) %} {% set t_att_precise = true %} {% endif %}
                                            {% if (cac >= 3) and (discretion >= 3) %} {% set t_att_surprise = true %} {% endif %}
                                            {% if (melee >= 4 or tir >= 4) and (reflexes >= 4) %} {% set t_celerite = true %} {% endif %}
                                            {% if (melee >= 3 or cac >= 3) and (puissance >= 3) %} {% set t_charge = true %} {% endif %}
                                            {% if (melee >= 3) and (reflexes >= 3) %} {% set t_deux_armes = true %} {% endif %}
                                            {% if (melee >= 3 or cac >= 3) %} {% set t_coup_bas = true %} {% endif %}
                                            {% if (melee >= 3) %} {% set t_finesse = true %} {% endif %}
                                            {% if (melee >= 3 or cac >= 3) and (puissance >= 3) %} {% set t_frappe_lourde = true %} {% endif %}
                                            {% if (melee >= 3 or bouclier >= 3) and (reflexes >= 3) %} {% set t_parade = true %} {% endif %}
                                            {% if (melee >= 3 or cac >= 3 or tir >= 3 or lancer >= 3 or bouclier >= 3) %} {% set t_polyvalence = true %} {% endif %}
                                            {% if (bouclier >= 3) and (puissance >= 3) %} {% set t_protection = true %} {% endif %}
                                            {% if (cac >= 3) and (puissance >= 3) %} {% set t_saisie = true %} {% endif %}
                                            {% if (tir >= 3 or lancer >= 3) and (reflexes >= 3) %} {% set t_tir_instinctif = true %} {% endif %}
                                            {% if (tir >= 3 or lancer >= 3) and (precision >= 3) %} {% set t_tir_precis = true %} {% endif %}
                                            {% if (tir >= 4 or lancer >= 4) and (reflexes >= 4) %} {% set t_volee = true %} {% endif %}

                                            <div class="row">
                                            {% if t_att_precise %}
                                                <div class="col-md-6 mb-2"><strong>Attaque précise:</strong> +1D ou +1Dgt (surpris/pris à revers). <em>(Mêlée Exp, Pré 3D)</em></div>
                                            {% endif %}
                                            {% if t_att_surprise %}
                                                <div class="col-md-6 mb-2"><strong>Attaque surprise:</strong> +1D ou +1Dgt sur la première attaque (surpris/revers). <em>(CàC Exp, Discrétion Exp)</em></div>
                                            {% endif %}
                                            {% if t_celerite %}
                                                <div class="col-md-6 mb-2"><strong>Célérité:</strong> 2 attaques (dont 1 mineure), mais ni bonus surdomaine/aide. <em>(Mêlée/Tir Mtr, Réf 4D)</em></div>
                                            {% endif %}
                                            {% if t_charge %}
                                                <div class="col-md-6 mb-2"><strong>Charge:</strong> +1Dgt, -1D défense. <em>(Mêlée/CàC Exp, Pui 3D)</em></div>
                                            {% endif %}
                                            {% if t_deux_armes %}
                                                <div class="col-md-6 mb-2"><strong>Combat à deux armes:</strong> +1Dgt, relance 1 dé rater attaque/défense. <em>(Mêlée Exp, Réf 3D)</em></div>
                                            {% endif %}
                                            {% if t_coup_bas %}
                                                <div class="col-md-6 mb-2"><strong>Coup bas:</strong> Remplace type de dégâts si désavantageux. <em>(Mêlée/CàC Exp)</em></div>
                                            {% endif %}
                                            {% if t_finesse %}
                                                <div class="col-md-6 mb-2"><strong>Finesse:</strong> Remplace Pui par Pré pour Dgt de base. <em>(Mêlée Exp)</em></div>
                                            {% endif %}
                                            {% if t_frappe_lourde %}
                                                <div class="col-md-6 mb-2"><strong>Frappe lourde:</strong> -1D attaque, +2 Dgt. <em>(Mêlée/CàC Exp, Pui 3D)</em></div>
                                            {% endif %}
                                            {% if t_parade %}
                                                <div class="col-md-6 mb-2"><strong>Parade experte:</strong> +1D défense, -1D attaque. <em>(Mêlée/Bouclier Exp, Réf 3D)</em></div>
                                            {% endif %}
                                            {% if t_polyvalence %}
                                                <div class="col-md-6 mb-2"><strong>Polyvalence:</strong> Change le type de dégâts avec l'arme actuelle. <em>(Toute comp. de combat Exp)</em></div>
                                            {% endif %}
                                            {% if t_protection %}
                                                <div class="col-md-6 mb-2"><strong>Protection protectrice:</strong> Remplace Dgt Pui par Bouclier ou encaisse Dgt. <em>(Bouclier Exp, Pui 3D)</em></div>
                                            {% endif %}
                                            {% if t_saisie %}
                                                <div class="col-md-6 mb-2"><strong>Saisie:</strong> 1 réussite Dgt = entraver la cible. <em>(CàC Exp, Pui 3D)</em></div>
                                            {% endif %}
                                            {% if t_tir_instinctif %}
                                                <div class="col-md-6 mb-2"><strong>Tir instinctif:</strong> Annule les malus de couvert. <em>(Tir/Lancer Exp, Réf 3D)</em></div>
                                            {% endif %}
                                            {% if t_tir_precis %}
                                                <div class="col-md-6 mb-2"><strong>Tir précis:</strong> +1D attaque, -1Dgt (tir ciblé) OU -1D attaque, +2Dgt. <em>(Tir/Lancer Exp, Pré 3D)</em></div>
                                            {% endif %}
                                            {% if t_volee %}
                                                <div class="col-md-6 mb-2"><strong>Volée:</strong> -1D attaque, 2 attaques au prix de 2 actions. <em>(Tir/Lancer Mtr, Réf 4D)</em></div>
                                            {% endif %}
                                            {% if not (t_att_precise or t_att_surprise or t_celerite or t_charge or t_deux_armes or t_coup_bas or t_finesse or t_frappe_lourde or t_parade or t_polyvalence or t_protection or t_saisie or t_tir_instinctif or t_tir_precis or t_volee) %}
                                                <div class="col-12 text-muted"><em>Aucune technique de combat débloquée pour le moment. Augmentez vos compétences de combat au niveau Expert (3) pour en obtenir.</em></div>
                                            {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
<div class="row">
                                <div class="col-md-6 mb-3">
                                    <div class="p-3 bg-dark border border-secondary rounded text-light h-100">
                                        <h5 class="text-light border-bottom border-secondary pb-2"><i class="fas fa-language"></i> Langues</h5>
                                        <ul id="list-langues" class="mb-0 mt-3 list-unstyled" data-langues="{{ favoriteCharacter.character.langues|default('[]')|escape('html_attr') }}">
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="p-3 bg-dark border border-secondary rounded text-light h-100">
                                        <h5 class="text-light border-bottom border-secondary pb-2"><i class="fas fa-star"></i> Spécialisations</h5>
                                        <ul id="list-specialites" class="mb-0 mt-3 list-unstyled" data-specialites="{{ favoriteCharacter.character.specialites|default('[]')|escape('html_attr') }}">
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Hidden storage for max values -->
                            <input type="hidden" id="max-effort" value="{{ favoriteCharacter.character.maxeffort|default(15) }}" />
                            <input type="hidden" id="max-sangfroid" value="{{ favoriteCharacter.character.maxsangfroid|default(8) }}" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- tab eclat -->
            <div class="tab-pane fade h-100" id="eclat-tab-pane" role="tabpanel" aria-labelledby="eclat-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-md-6 h-100 pr-2 pl-0">
                        <div class="d-flex flex-column h-100">
                            <div class="head-card square-tl my-0 d-flex justify-content-between align-items-center">
                                <span>Relique d'Éclat 
                                {% if favoriteCharacter.character.stadeEclat %}
                                    <span class="text-warning ml-2" style="font-size: 0.9rem;">({{ favoriteCharacter.character.stadeEclat }})</span>
                                {% endif %}
                                </span>
                            </div>
                            <div class="body-card p-3 d-flex flex-column" style="flex: 1; overflow-y: auto;">
                                {% if not favoriteCharacter.character.stadeEclat or favoriteCharacter.character.stadeEclat == '' %}
                                    <div class="text-center text-muted mt-3">
                                        <em>Cette âme ne possède aucun Éclat (Pacte de Rencontre non scellé).</em>
                                    </div>
                                {% else %}
                                    <div class="mb-3">
                                        <h6 class="text-warning font-weight-bold" style="font-family: 'Cinzel', serif; border-bottom: 1px solid rgba(255,215,0,0.3); padding-bottom: 5px;">Forme et Sphère</h6>
                                        <p class="mb-1"><strong>Forme :</strong> {{ favoriteCharacter.character.formeEclat|default('Non définie') }}</p>
                                        <p class="mb-0"><strong>Sphère d'Influence :</strong> {{ favoriteCharacter.character.sphereEclat|default('Non définie') }}</p>
                                    </div>
                                    <div class="mb-3">
                                        <h6 class="text-warning font-weight-bold" style="font-family: 'Cinzel', serif; border-bottom: 1px solid rgba(255,215,0,0.3); padding-bottom: 5px;">Apparence</h6>
                                        <p class="mb-0" style="white-space: pre-wrap;">{{ favoriteCharacter.character.apparenceEclat|default('Aucune description') }}</p>
                                    </div>
                                    <div class="mb-3">
                                        <h6 class="text-warning font-weight-bold" style="font-family: 'Cinzel', serif; border-bottom: 1px solid rgba(255,215,0,0.3); padding-bottom: 5px;">Embrasement</h6>
                                        <p class="mb-0" style="white-space: pre-wrap; font-style: italic;">{{ favoriteCharacter.character.embrasementEclat|default("Aucune condition d'embrasement définie") }}</p>
                                    </div>
                                    <div class="mb-3">
                                        <h6 class="text-warning font-weight-bold mb-2" style="font-family: 'Cinzel', serif; border-bottom: 1px solid rgba(255,215,0,0.3); padding-bottom: 5px;">Capacités d'Éclat</h6>
                                        <ul class="list-group" id="dashboard-capacites-list" style="border: 1px solid rgba(255, 215, 0, 0.2); border-radius: 5px; background: rgba(0,0,0,0.3);">
                                            {% set capacites = favoriteCharacter.character.capacitesEclat|default('[]')|trim %}
                                            <script>
                                                document.addEventListener('DOMContentLoaded', () => {
                                                    const container = document.getElementById('dashboard-capacites-list');
                                                    let capsStr = `{{ capacites|raw }}`;
                                                    let caps = [];
                                                    try { caps = JSON.parse(capsStr); } catch(e) {}

                                                    // Centralisé : allEclatCapacites injecté côté backend
                                                    const allEclatCapacites = {{ allEclatCapacites|json_encode|raw }};
                                                    // Crée un mapping nom -> desc
                                                    let capDescMap = {};
                                                    Object.values(allEclatCapacites).forEach(arr => {
                                                        arr.forEach(obj => { capDescMap[obj.nom] = obj.desc; });
                                                    });

                                                    if (Array.isArray(caps) && caps.length > 0) {
                                                        caps.forEach(cap => {
                                                            const li = document.createElement('li');
                                                            li.className = 'list-group-item bg-transparent text-light border-secondary p-2 mb-1';
                                                            let desc = capDescMap[cap] ? `<div class='small text-warning mt-1' style='font-size:0.95em;'>${capDescMap[cap]}</div>` : "<div class='small text-muted mt-1'>Description non trouvée.</div>";
                                                            li.innerHTML = `<i class="fas fa-bolt text-warning mr-2" style="opacity: 0.8;"></i> <span class='fw-bold'>${cap}</span>${desc}`;
                                                            container.appendChild(li);
                                                        });
                                                    } else {
                                                        container.innerHTML = '<li class="list-group-item bg-transparent text-muted border-0 p-2 text-center" style="font-style: italic;">Aucune capacité ralliée</li>';
                                                    }
                                                });
                                            </script>
                                        </ul>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6 h-100 pl-2 pr-0">
                        <div class="d-flex flex-column h-100">
                            <div class="head-card square-tr my-0">Faveurs Accordées</div>
                            <div class="body-card p-3 d-flex flex-column" style="flex: 1; overflow-y: auto;">
                                <!-- Faveurs List -->
                                <div class="row mx-0" id="dashboard-faveurs-list">
                                    {% set faveursList = favoriteCharacter.character.faveurs|default('[]')|trim %}
                                    <script>
                                    document.addEventListener('DOMContentLoaded', () => {
                                        const container = document.getElementById('dashboard-faveurs-list');
                                        let favStr = `{{ faveursList|e('js') }}`;
                                        let allFaveurs = {{ allFaveurs|json_encode|raw }};
                                        let allFaveursMap = {};
                                        allFaveurs.forEach(fav => { allFaveursMap[fav.nom] = fav; });
                                        try {
                                            if (favStr) {
                                                const faveurs = JSON.parse(favStr);
                                                if (Array.isArray(faveurs) && faveurs.length > 0) {
                                                    container.innerHTML = '';
                                                    faveurs.forEach(f => {
                                                        const faveur = allFaveursMap[f];
                                                        let html = `<div class='col-12 mb-3 px-0'><div class='card h-100 bg-dark text-light' style='border: 1px solid rgba(255,215,0,0.5);'><div class='card-header font-weight-bold text-warning d-flex justify-content-between align-items-center' style='background-color: rgba(255,215,0,0.1);'><h6 class='mb-0' style="font-family: 'Cinzel', serif;">${f}</h6></div><div class='card-body p-2' style='font-size: 0.9rem;'>`;
                                                        if (faveur) {
                                                            html += `<p class='mb-2' style='font-size: 0.9rem; color: #aaa;'><i class='fas fa-circle' style='font-size: 0.5rem; vertical-align: middle; margin-right: 5px;'></i><strong>Type :</strong> ${faveur.type} | <strong>Stade :</strong> ${faveur.stade}</p><p class='card-text text-light' style='font-size: 0.95rem;'>${faveur.description}</p>`;
                                                        } else {
                                                            html += `<p class='text-muted mb-0'>Description non trouvée ou Faveur personnalisée.</p>`;
                                                        }
                                                        html += `</div></div></div>`;
                                                        container.insertAdjacentHTML('beforeend', html);
                                                    });
                                                } else {
                                                    container.innerHTML = "<div class='col-12 text-center text-muted mt-3'><em>Aucune faveur accordée à cette âme.</em></div>";
                                                }
                                            }
                                        } catch (e) {
                                            console.error("Error parsing faveurs JSON:", e);
                                            container.innerHTML = "<div class='col-12 text-center text-danger mt-3'>Erreur lors de la récupération des faveurs.</div>";
                                        }
                                    });
                                    </script>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- tab rituels -->
            <div class="tab-pane fade h-100" id="rituels-tab-pane" role="tabpanel" aria-labelledby="rituels-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-12 h-100 px-0">
                        <div class="head-card square-tl square-tr">Rituels Maîtrisés</div>
                        <div class="body-card p-3" style="height: 100%; overflow-y: auto;">
                            <div class="row" id="rituels-list">
                                {% set masteredRituals = favoriteCharacter.character.rituelsMaitrises|default('[]')|trim %}
                                {# The mastered rituals string is JSON encoded array of strings e.g. '["Rituel 1", "Rituel 2"]' #}
                                <script>
                                    document.addEventListener('DOMContentLoaded', () => {
                                        const rituelsContainer = document.getElementById('rituels-list');
                                        let masteredRitualsStr = `{{ masteredRituals|raw }}`;
                                        try {
                                            if (masteredRitualsStr) {
                                                const masteredRituals = JSON.parse(masteredRitualsStr);
                                                if (Array.isArray(masteredRituals) && masteredRituals.length > 0) {
                                                    rituelsContainer.innerHTML = '<div class="col-12 text-center text-muted mt-3"><em>Chargement des descriptions des rituels...</em></div>';
                                                    
                                                    fetch('/rituels')
                                                        .then(res => res.text())
                                                        .then(html => {
                                                            const parser = new DOMParser();
                                                            const doc = parser.parseFromString(html, 'text/html');
                                                            const headers = Array.from(doc.querySelectorAll('.card-header'));
                                                            
                                                            rituelsContainer.innerHTML = '';
                                                            masteredRituals.forEach(r => {
                                                                let descHtml = '<p class="text-muted mb-0">Description non trouvée.</p>';
                                                                const headerMatch = headers.find(h => h.textContent.includes(r));
                                                                if (headerMatch && headerMatch.nextElementSibling && headerMatch.nextElementSibling.classList.contains('card-body')) {
                                                                    descHtml = headerMatch.nextElementSibling.innerHTML;
                                                                }
                                                                
                                                                const div = document.createElement('div');
                                                                div.className = 'col-12 mb-3';
                                                                div.innerHTML = `
                                                                    <div class="card h-100 bg-dark text-light border border-secondary">
                                                                        <div class="card-header bg-secondary font-weight-bold text-warning d-flex justify-content-between align-items-center">
                                                                            <h5 class="mb-0 text-warning">${r}</h5>
                                                                            <button class="btn btn-sm btn-outline-danger" onclick="removeRitual('${r}')">
                                                                                <i class="fas fa-trash"></i> Retirer
                                                                            </button>
                                                                        </div>
                                                                        <div class="card-body" style="font-size: 0.95rem;">
                                                                            ${descHtml}
                                                                        </div>
                                                                    </div>
                                                                `;
                                                                rituelsContainer.appendChild(div);
                                                            });
                                                        })
                                                        .catch(err => {
                                                            console.error('Erreur lors du chargement des rituels', err);
                                                            rituelsContainer.innerHTML = '';
                                                            masteredRituals.forEach(r => {
                                                                const div = document.createElement('div');
                                                                div.className = 'col-md-6 mb-3';
                                                                div.innerHTML = `
                                                                    <div class="card h-100 bg-dark text-light border border-secondary">
                                                                        <div class="card-header bg-secondary d-flex justify-content-between align-items-center">
                                                                            <h5 class="card-title mb-0 text-warning">${r}</h5>
                                                                            <button class="btn btn-sm btn-outline-danger" onclick="removeRitual('${r}')">
                                                                                <i class="fas fa-trash"></i>
                                                                            </button>
                                                                        </div>
                                                                        <div class="card-body">
                                                                            <p class="text-danger small">Impossible de récupérer la description.</p>
                                                                        </div>
                                                                    </div>
                                                                `;
                                                                rituelsContainer.appendChild(div);
                                                            });
                                                        });
                                                } else {
                                                    rituelsContainer.innerHTML = '<div class="col-12 text-muted"><em>Aucun rituel maîtrisé pour ce personnage.</em></div>';
                                                }
                                            } else {
                                                rituelsContainer.innerHTML = '<div class="col-12 text-muted"><em>Aucun rituel maîtrisé pour ce personnage.</em></div>';
                                            }
                                        } catch(e) {
                                            console.error('Error parsing rituals', e);
                                            rituelsContainer.innerHTML = '<div class="col-12 text-muted"><em>Erreur de chargement des rituels.</em></div>';
                                        }
                                    });

                                    function removeRitual(ritualName) {
                                        if(!confirm(`Voulez-vous vraiment retirer le rituel "${ritualName}" ?`)) return;
                                        
                                        fetch('/rituels/remove', {
                                            method: 'POST',
                                            headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify({
                                                characterId: '{{ favoriteCharacter.character.id_Character }}',
                                                ritualName: ritualName
                                            })
                                        })
                                        .then(response => response.json())
                                        .then(data => {
                                            if (data.success) {
                                                window.location.reload();
                                            } else {
                                                alert("Erreur: " + data.message);
                                            }
                                        })
                                        .catch(err => {
                                            console.error(err);
                                            alert("Une erreur est survenue.");
                                        });
                                    }
                                </script>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- tab groupe -->
            <div class="tab-pane fade h-100" id="groupe-tab-pane" role="tabpanel" aria-labelledby="groupe-tab" tabindex="0">
                <div class="row h-100 mx-0">
                    <div class="col-12 h-100 px-0">
                        <div class="head-card square-tl square-tr">Groupe</div>
                        <div class="body-card p-3" style="height: 100%; overflow-y: auto;">
                            {% if favoriteCharacter.character.Groupe is defined and favoriteCharacter.character.Groupe %}
                                <!-- The user is IN a group -->
                                <h4>{{ favoriteCharacter.character.Groupe.nom }}</h4>
                                <hr>
                                <div class="row mb-3">
                                    <div class="col-md-4 text-center">
                                        <div class="badge bg-dark border border-secondary text-light w-100 fs-6 p-2">Niveau {{ favoriteCharacter.character.Groupe.niveau }}</div>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <div class="badge bg-dark border border-secondary text-light w-100 fs-6 p-2">Réputation: {{ favoriteCharacter.character.Groupe.reputation }}</div>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <div class="badge bg-dark border border-secondary text-light w-100 fs-6 p-2" id="groupe-dice-display" data-grp-id="{{ favoriteCharacter.character.Groupe.id }}" data-grp-niveau="{{ favoriteCharacter.character.Groupe.niveau }}">
                                            Dés: {{ favoriteCharacter.character.Groupe.reserveDes }} / 
                                            {% if favoriteCharacter.character.Groupe.niveau == 1 %}12{% elseif favoriteCharacter.character.Groupe.niveau == 2 %}14{% else %}16{% endif %}
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-4 d-flex justify-content-evenly mt-3">
                                    <button class="btn btn-outline-success px-4 py-2 fw-bold d-flex align-items-center gap-2" style="border-radius: 25px; transition: all 0.3s ease; background: rgba(25, 135, 84, 0.1);" onmouseover="this.style.backgroundColor='rgba(25, 135, 84, 0.2)'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='rgba(25, 135, 84, 0.1)'; this.style.transform='translateY(0)';" onclick="ajouterDesGroupe({{ favoriteCharacter.character.Groupe.id }}, {{ favoriteCharacter.character.Groupe.niveau }})">
                                        <i class="fas fa-plus-circle"></i> Ajouter 1 Dé
                                    </button>
                                    <button class="btn btn-outline-danger px-4 py-2 fw-bold d-flex align-items-center gap-2" style="border-radius: 25px; transition: all 0.3s ease; background: rgba(220, 53, 69, 0.1);" onmouseover="this.style.backgroundColor='rgba(220, 53, 69, 0.2)'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='rgba(220, 53, 69, 0.1)'; this.style.transform='translateY(0)';" onclick="depenserDesGroupe({{ favoriteCharacter.character.Groupe.id }})">
                                        <i class="fas fa-minus-circle"></i> Dépenser 1 Dé
                                    </button>
                                </div>
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h5 class="m-0">Instinct: <span id="current-instinct-name">{{ favoriteCharacter.character.Groupe.instinctGroupe }}</span></h5>
                                    </div>
                                    <div class="p-3 bg-dark border border-secondary rounded text-light" id="current-instinct-details">
                                        <p><em>{{ favoriteCharacter.character.Groupe.capacitesInstinctGroupe }}</em></p>
                                    </div>
                                </div>
                                
                                <div class="mb-3 mt-4 text-light p-3 border border-secondary rounded bg-dark">
                                    <h5 class="text-light border-bottom border-secondary pb-2"><i class="fas fa-book"></i> Règles : Perdre et Regagner des Dés de Réserve de Groupe</h5>
                                    
                                    <div class="row">
                                      <div class="col-md-6">
                                        <!-- title --><h6 class="text-danger mt-2">Dépenses & Pertes</h6>
                                        <ul class=" mb-0" style="list-style-type: none; padding-left: 0;">
                                            <li><span class="text-danger fw-bold">-1D</span> : Tension mineure (brouille, désaccord), ou Découragement (fatigue, faim, soif)</li>
                                            <li><span class="text-danger fw-bold">-2D à -3D</span> : Coup dur (vol, perte d'équipement, mauvaise nouvelle)</li>
                                            <li><span class="text-danger fw-bold">-3D</span> : Tension majeure (conflit, accusation grave)</li>
                                            <li><span class="text-danger fw-bold">-3D à -5D</span> : Interdit de l'Instinct enfreint</li>
                                            <li><span class="text-danger fw-bold">-5D</span> : Choc (mort d'un membre, trahison)</li>
                                        </ul>
                                      </div>
                                      <div class="col-md-6">
                                        <!-- title --><h6 class="text-success mt-2">Gains de Dés</h6>
                                        <ul class=" mb-0" style="list-style-type: none; padding-left: 0;">
                                            <li><span class="text-success fw-bold">+1D</span> : Bon moment partagé (repas, échange)</li>
                                            <li><span class="text-success fw-bold">+1D à +2D</span> : Cohésion (action collective, esprit d'équipe)</li>
                                            <li><span class="text-success fw-bold">+2D à +3D</span> : Communauté (réussite collective, harmonie)</li>
                                            <li><span class="text-success fw-bold">+3D à +5D</span> : Principe de l'Instinct accompli</li>
                                            <li><span class="text-success fw-bold">+5D à Max</span> : Accomplissement (Objectif majeur)</li>
                                        </ul>
                                      </div>
                                    </div>
                                    <p class=" text-light mt-3 mb-0"><em>Note: Les principes et interdits suivis d'un astérisque (*) peuvent faire gagner ou perdre jusqu'à 4D dans chacune des Réserves s'ils sont significatifs pour le Groupe.</em></p>
                                </div>
                                <div class="mb-3">
                                    <h5>Capacités de Groupe:</h5>
                                    <ul>
                                        <li><strong>Unité:</strong> +1D aux actions collectives</li>
                                        <li><strong>Expertise partagée:</strong> +1 réussite si un membre du groupe possède la compétence (Expert)</li>
                                        <li>{{ favoriteCharacter.character.Groupe.capacitesGroupe }}</li>
                                    </ul>
                                </div>
                                <div class="text-end mt-4 mb-2">
                                    <!-- Quitter button --><button style="color: #d9534f; text-decoration: underline; background: none; border: none; padding: 0; font-size: 0.9em; cursor: pointer;" onmouseover="this.style.color='#ff6b6b'" onmouseout="this.style.color='#d9534f'" onclick="quitterGroupe({{ favoriteCharacter.character.id_Character }})">Quitter le groupe</button>
                                </div>
                            {% else %}
                                <!-- The user is NOT in a group -->
                                <p>Rejoignez un groupe existant ou créez-en un nouveau.</p>

                                <h5>Rejoindre un groupe</h5>
                                <div class="d-flex mb-4">
                                    <select class="form-select me-2" id="group-select" style="min-width: 200px;">
                                        {% if allGroupes is defined and allGroupes|length > 0 %}
                                            {% for grp in allGroupes %}
                                                <option value="{{ grp.id }}">{{ grp.nom }} (Niveau {{ grp.niveau }})</option>
                                            {% endfor %}
                                        {% else %}
                                            <option value="">Aucun groupe disponible</option>
                                        {% endif %}
                                    </select>
                                    <button class="btn btn-success" onclick="rejoindreGroupe({{ favoriteCharacter.character.id_Character }})">Rejoindre</button>
                                </div>

                                <hr>

                                <h5>Créer un groupe</h5>
                                <form id="create-group-form">
                                    <div class="mb-2">
                                        <label>Nom du Groupe</label>
                                        <input type="text" class="form-control bg-dark text-light border-secondary" id="new-group-name" required>
                                    </div>
                                    <div class="mb-2">
                                        <label>Instinct du Groupe</label>
                                        <select class="form-select bg-dark text-light border-secondary" id="new-group-instinct" required>
                                            <option value="architecte">L’Architecte</option>
                                            <option value="epee">L’Épée</option>
                                            <option value="fleau">Le Fléau</option>
                                            <option value="gardien">Le Gardien</option>
                                            <option value="homme">L’Homme</option>
                                            <option value="main">La Main</option>
                                            <option value="masque">Le Masque</option>
                                            <option value="neant">Le Néant</option>
                                            <option value="os">L’Os</option>
                                            <option value="voyageur">Le Voyageur</option>
                                        </select>
                                    </div>
                                    <div id="groupInstinctDescriptionBlock" class="p-2 mb-2 bg-dark text-light border border-secondary rounded" style="display: none;">
                                        <h6 id="groupInstinctTitle" class="mb-1 fw-bold"></h6>
                                        <p id="groupInstinctText" class="mb-1 " style="font-style: italic;"></p>
                                        <div id="groupInstinctStats" class=" text-warning" style="border-top: 1px solid #666; padding-top: 5px; margin-top: 5px;"></div>
                                    </div>
                                    <button type="button" class="btn btn-success mt-2" onclick="creerGroupe({{ favoriteCharacter.character.id_Character }})">Créer</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>
<!-- Add Item Modal -->
<div class="modal fade" id="addItemModal" tabindex="-1" role="dialog" aria-labelledby="addItemModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content text-dark">
      <div class="modal-header">
        <h5 class="modal-title" id="addItemModalLabel">Ajouter un objet</h5>
        <button type="button" class="close btn btn-link" data-bs-dismiss="modal" aria-label="Close" style="color: black; text-decoration: none; font-size: 1.5rem;">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <ul class="nav nav-tabs" id="itemTabs" role="tablist">
          <li class="nav-item">
            <a class="nav-link active" id="premade-item-tab" data-bs-toggle="tab" href="#premade-item" role="tab">Dans le manuel</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="custom-item-tab" data-bs-toggle="tab" href="#custom-item" role="tab">Objet personnalisé</a>
          </li>
        </ul>
        <div class="tab-content mt-3" id="itemTabsContent">
          <!-- Premade Item -->
          <div class="tab-pane fade show active" id="premade-item" role="tabpanel">
             <div class="form-group">
                <label for="item-select">Sélectionner un objet</label>
                <select id="item-select" class="form-control">
                    <option value="">Sélectionnez...</option>
                    {% for item in equipmentList %}
                        <option value="{{ loop.index0 }}" 
                                data-name="{{ item.name }}" 
                                data-type="{{ item.type }}" 
                                data-stats="{{ item.stats }}" 
                                data-desc="{{ item.desc }}">
                            {{ item.name }} ({{ item.type }}) - {{ item.price }} Or - Rareté {{ item.rarity }}
                        </option>
                    {% endfor %}
                </select>
             </div>
          </div>
          <!-- Custom Item -->
          <div class="tab-pane fade" id="custom-item" role="tabpanel">
             <div class="form-group">
