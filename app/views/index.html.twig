<script src="https://cdn.jsdelivr.net/npm/quill@1.3.6/dist/quill.js"></script>
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.6/dist/quill.snow.css" rel="stylesheet">
<script src="/js/dashboardQuill.js"></script>
<script src="/js/dashboardForm.js"></script>

<script src="/js/dashboardTrackRolls.js"></script>

{# Librairies dés #}
<script src="/js/bundle.js"></script>
<script src="/js/dashboardInventory.js"></script>
<script src="/js/dashboardGroupe.js"></script>
<script src="/js/dashboardRessources.js?v=1775566188"></script>
<script src="/js/character_data.js"></script>
<script>
document.addEventListener("DOMContentLoaded", () => {
    if (typeof origineDescriptions === 'undefined' || typeof instinctDescriptions === 'undefined') return;

    function normalizeString(str) {
        if (!str) return "";
        return str.toLowerCase().replace(/['’]/g, "").trim();
    }

    function findDescription(type, name) {
        if (!name || name === 'Aucun' || name === 'Aucune' || name === 'none') return null;
        let safeName = name.replace(/['’]/g, "."); 

        if (type === 'Avantage' || type === 'Désavantage' || type === 'Spécial') {
            for (const key in origineDescriptions) {
                const stats = origineDescriptions[key].stats;
                if (!stats) continue;
                const regex = new RegExp('<b>' + type + '(?:\\s+|&nbsp;|&#160;|\\u2013|-)*' + safeName + '\\s*:\\s*<\\/b>(.*?)(?:<br|$)', 'is');
                const match = stats.match(regex);
                if (match) return match[1].trim();
            }
        }
        
        if (type === "Capacité d'Instinct") {
            for (const key in instinctDescriptions) {
                const stats = instinctDescriptions[key].stats;
                if (!stats) continue;
                const regex = new RegExp('<b>Capacité d\'Instinct(?:\\s+|&nbsp;|&#160;|\\u2013|-)*' + safeName + '\\s*:\\s*<\\/b>(.*?)(?:<br|$)', 'is');
                const match = stats.match(regex);
                if (match) return match[1].trim();
            }
        }
        
        if (type === "TextInstinct") {
            const search = normalizeString(name);
            for (const key in instinctDescriptions) {
                const title = normalizeString(instinctDescriptions[key].title);
                if (title === search || title.includes(search) || search.includes(title)) {
                    let res = instinctDescriptions[key].text;
                    if (instinctDescriptions[key].stats) {
                        const parts = instinctDescriptions[key].stats.split('<br><br>');
                        const cleanParts = parts.filter(p => !p.includes("<b>Avantage") && !p.includes("<b>Désavantage") && !p.includes("<b>Capacité d\'Instinct"));
                        if (cleanParts.length > 0) {
                            res += "<div style='margin-top:10px; padding-top:10px; border-top:1px solid #555; color:#fff; font-style:normal;'>" + cleanParts.join('<br><br>') + "</div>";
                        }
                    }
                    return res;
                }
            }
        }

        if (type === "TextOrigine") {
            const search = normalizeString(name);
            for (const key in origineDescriptions) {
                const title = normalizeString(origineDescriptions[key].title);
                if (title === search || title.includes(search) || search.includes(title) || (search === 'akshan' && title.includes('khashan'))) {
                    let res = origineDescriptions[key].text;
                    if (origineDescriptions[key].stats) {
                        const parts = origineDescriptions[key].stats.split('<br><br>');
                        const cleanParts = parts.filter(p => !p.includes("<b>Avantage") && !p.includes("<b>Désavantage") && !p.includes("<b>Capacité d\'Instinct"));
                        if (cleanParts.length > 0) {
                            res += "<div style='margin-top:10px; padding-top:10px; border-top:1px solid #555; color:#fff; font-style:normal;'>" + cleanParts.join('<br><br>') + "</div>";
                        }
                    }
                    return res;
                }
            }
        }

        return null;
    }

    const setDesc = (nomId, descId, typeType, altType) => {
        const nomEl = document.getElementById(nomId);
        const descEl = document.getElementById(descId);
        if (nomEl && descEl && nomEl.innerText && nomEl.innerText !== 'Aucune' && nomEl.innerText !== 'Aucun avantage' && nomEl.innerText !== 'Aucun désavantage' && nomEl.innerText !== 'Aucun' && nomEl.innerText !== 'none' && nomEl.innerText !== 'Aucun instinct sélectionné') {
            let desc = findDescription(typeType, nomEl.innerText);
            if (!desc && altType) desc = findDescription(altType, nomEl.innerText);
            if (desc) descEl.innerHTML = desc;
        }
    };

    setDesc("nom-cap-1", "desc-cap-1", "Capacité d'Instinct");
    setDesc("nom-avantage", "desc-avantage", "Avantage", "Spécial");
    setDesc("nom-desavantage", "desc-desavantage", "Désavantage");
    setDesc("nom-instinct", "desc-instinct", "TextInstinct");
    setDesc("nom-origine", "desc-origine", "TextOrigine");
});
</script>
